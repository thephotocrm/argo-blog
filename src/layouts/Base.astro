---
import SEOHead from '../components/SEOHead.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
  keywords?: string[];
  jsonLd?: object;
}

const {
  title,
  description,
  image = '/og-images/default.png',
  type = 'website',
  publishedDate,
  keywords = [],
  jsonLd,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

const categories = [
  { name: 'Business', href: '/blog' },
  { name: 'Pricing', href: '/tools/pricing-calculator' },
  { name: 'Workflow', href: '/blog' },
  { name: 'Marketing', href: '/blog' },
  { name: 'Tools', href: '/tools/pricing-calculator' },
  { name: 'Resources', href: '/faq' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-KHTS8D78JQ"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-KHTS8D78JQ');
    </script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SEOHead
      title={title}
      description={description}
      image={image}
      type={type}
      url={canonicalUrl.href}
      publishedDate={publishedDate}
      keywords={keywords}
      jsonLd={jsonLd}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Instrument+Serif:ital@0;1&family=Space+Mono:wght@400;700&family=Syne:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --color-night: #0b0f1a;
        --color-deep-water: #141829;
        --color-fleece-gold: #c9a227;
        --color-pale-gold: #e2cc6b;
        --color-starlight: #d4cabb;
        --color-parchment: #f0ebe1;
        --color-frost: #f7f5f0;
        --color-slate: #6b7280;
        --color-compass-blue: #4a6fa5;
        --color-accent: #c9a227;
        --color-card-bg: #ffffff;
        --color-border: rgba(0, 0, 0, 0.06);
        --font-display: 'Instrument Serif', serif;
        --font-body: 'DM Sans', sans-serif;
        --font-mono: 'Space Mono', monospace;
        --font-accent: 'Syne', sans-serif;
        --container-wide: 1200px;
        --container: 720px;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: var(--font-body);
        color: var(--color-night);
        background: var(--color-frost);
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
      }

      h1, h2, h3, h4 {
        font-family: var(--font-display);
        font-weight: 400;
        line-height: 1.2;
      }

      h1 { font-size: 2.75rem; }
      h2 { font-size: 1.75rem; margin-top: 2.5rem; margin-bottom: 1rem; }
      h3 { font-size: 1.35rem; margin-top: 2rem; margin-bottom: 0.75rem; }

      a {
        color: var(--color-compass-blue);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      code, pre {
        font-family: var(--font-mono);
        font-size: 0.875rem;
      }

      .overline {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--color-fleece-gold);
      }

      .container {
        max-width: var(--container);
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      .container-wide {
        max-width: var(--container-wide);
        margin: 0 auto;
        padding: 0 2rem;
      }

      img {
        max-width: 100%;
        height: auto;
      }
    </style>
  </head>
  <body>
    <!-- Top bar -->
    <div class="top-bar">
      <div class="container-wide">
        <div class="top-bar-inner">
          <div class="top-bar-left">
            <a href="https://argostudio.co" rel="noopener">argostudio.co</a>
          </div>
          <div class="top-bar-right">
            <a href="/faq">Help</a>
            <a href="https://argostudio.co/signup" rel="noopener">Sign Up</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Main header -->
    <header class="site-header">
      <div class="container-wide">
        <div class="header-main">
          <a href="/" class="logo">Argo Studio</a>
          <div class="header-right">
            <div class="social-links">
              <a href="#" aria-label="Twitter" class="social-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
              <a href="#" aria-label="Instagram" class="social-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              </a>
              <a href="#" aria-label="YouTube" class="social-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/><path fill="#fff" d="M9.545 15.568V8.432L15.818 12z"/></svg>
              </a>
            </div>
            <a href="https://argostudio.co" class="nav-cta" rel="noopener">Get Started</a>
          </div>
        </div>
      </div>
    </header>

    <!-- Category nav -->
    <nav class="category-nav">
      <div class="container-wide">
        <div class="category-nav-inner">
          {categories.map((cat) => (
            <a href={cat.href} class="category-link">{cat.name}</a>
          ))}
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <!-- Newsletter footer -->
    <section class="newsletter-footer">
      <div class="container-wide">
        <div class="newsletter-inner">
          <div class="newsletter-text">
            <h2>Sign Up for Our Newsletter</h2>
            <p>Get photography business tips, pricing strategies, and workflow advice delivered to your inbox.</p>
          </div>
          <form class="newsletter-form" action="https://argostudio.co/signup" method="get">
            <input type="email" placeholder="Enter your email" required />
            <button type="submit">Subscribe</button>
          </form>
        </div>
      </div>
    </section>

    <footer class="site-footer">
      <div class="container-wide">
        <div class="footer-grid">
          <div>
            <a href="/" class="footer-logo">Argo Studio</a>
            <p class="footer-desc">Business management built for photographers. Contracts, invoices, scheduling, and client communication in one place.</p>
            <div class="footer-social">
              <a href="#" aria-label="Twitter">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
              <a href="#" aria-label="Instagram">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              </a>
              <a href="#" aria-label="YouTube">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/><path fill="var(--color-night)" d="M9.545 15.568V8.432L15.818 12z"/></svg>
              </a>
            </div>
          </div>
          <div>
            <p class="footer-heading">Resources</p>
            <ul>
              <li><a href="/blog">Blog</a></li>
              <li><a href="/tools/pricing-calculator">Pricing Calculator</a></li>
              <li><a href="/tools/roi-calculator">ROI Calculator</a></li>
              <li><a href="/faq">FAQ</a></li>
            </ul>
          </div>
          <div>
            <p class="footer-heading">Product</p>
            <ul>
              <li><a href="https://argostudio.co" rel="noopener">Main Site</a></li>
              <li><a href="https://argostudio.co/pricing" rel="noopener">Pricing</a></li>
              <li><a href="https://argostudio.co/signup" rel="noopener">Sign Up</a></li>
            </ul>
          </div>
        </div>
        <p class="footer-copy">&copy; {new Date().getFullYear()} Argo Studio. All rights reserved.</p>
      </div>
    </footer>

    <style>
      /* Top bar */
      .top-bar {
        background: var(--color-night);
        padding: 0.5rem 0;
        font-size: 0.8rem;
      }
      .top-bar-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .top-bar a {
        color: var(--color-starlight);
        transition: color 0.15s;
      }
      .top-bar a:hover {
        color: var(--color-pale-gold);
        text-decoration: none;
      }
      .top-bar-right {
        display: flex;
        gap: 1.5rem;
      }

      /* Main header */
      .site-header {
        padding: 1.25rem 0;
        background: var(--color-frost);
        border-bottom: 1px solid var(--color-border);
      }
      .header-main {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .logo {
        font-family: var(--font-display);
        font-size: 1.75rem;
        color: var(--color-night);
        letter-spacing: -0.02em;
      }
      .logo:hover { text-decoration: none; }
      .header-right {
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }
      .social-links {
        display: flex;
        gap: 0.75rem;
      }
      .social-icon {
        color: var(--color-slate);
        transition: color 0.15s;
        display: flex;
        align-items: center;
      }
      .social-icon:hover {
        color: var(--color-fleece-gold);
        text-decoration: none;
      }
      .nav-cta {
        background: var(--color-fleece-gold);
        color: var(--color-night);
        padding: 0.6rem 1.5rem;
        border-radius: 4px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: opacity 0.15s;
      }
      .nav-cta:hover { text-decoration: none; opacity: 0.9; }

      /* Category nav */
      .category-nav {
        border-bottom: 2px solid var(--color-border);
        background: var(--color-card-bg);
      }
      .category-nav-inner {
        display: flex;
        gap: 2rem;
        padding: 0.85rem 0;
        overflow-x: auto;
      }
      .category-link {
        font-family: var(--font-body);
        font-weight: 700;
        font-size: 0.85rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--color-night);
        white-space: nowrap;
        transition: color 0.15s;
        position: relative;
      }
      .category-link:hover {
        color: var(--color-fleece-gold);
        text-decoration: none;
      }
      .category-link::after {
        content: '';
        position: absolute;
        bottom: -0.85rem;
        left: 0;
        right: 0;
        height: 2px;
        background: var(--color-fleece-gold);
        transform: scaleX(0);
        transition: transform 0.2s;
      }
      .category-link:hover::after {
        transform: scaleX(1);
      }

      /* Newsletter footer */
      .newsletter-footer {
        background: var(--color-deep-water);
        padding: 3.5rem 0;
      }
      .newsletter-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 3rem;
      }
      .newsletter-text h2 {
        color: var(--color-parchment);
        font-size: 1.75rem;
        margin: 0;
      }
      .newsletter-text p {
        color: var(--color-starlight);
        margin-top: 0.5rem;
        max-width: 400px;
      }
      .newsletter-form {
        display: flex;
        gap: 0;
        flex-shrink: 0;
      }
      .newsletter-form input {
        padding: 0.85rem 1.25rem;
        border: 1px solid rgba(255,255,255,0.15);
        border-right: none;
        border-radius: 4px 0 0 4px;
        background: rgba(255,255,255,0.08);
        color: var(--color-parchment);
        font-family: var(--font-body);
        font-size: 0.95rem;
        width: 280px;
      }
      .newsletter-form input::placeholder {
        color: var(--color-slate);
      }
      .newsletter-form button {
        padding: 0.85rem 1.75rem;
        background: var(--color-fleece-gold);
        color: var(--color-night);
        border: none;
        border-radius: 0 4px 4px 0;
        font-family: var(--font-body);
        font-weight: 700;
        font-size: 0.9rem;
        cursor: pointer;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: opacity 0.15s;
      }
      .newsletter-form button:hover { opacity: 0.9; }

      /* Footer */
      .site-footer {
        padding: 3rem 0 2rem;
        background: var(--color-night);
        color: var(--color-starlight);
      }
      .footer-grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: 3rem;
        margin-bottom: 2rem;
      }
      .footer-logo {
        font-family: var(--font-display);
        font-size: 1.35rem;
        color: var(--color-parchment);
      }
      .footer-logo:hover { text-decoration: none; }
      .footer-desc {
        margin-top: 0.75rem;
        font-size: 0.9rem;
        line-height: 1.6;
        color: var(--color-slate);
      }
      .footer-social {
        display: flex;
        gap: 1rem;
        margin-top: 1rem;
      }
      .footer-social a {
        color: var(--color-starlight);
        transition: color 0.15s;
        display: flex;
      }
      .footer-social a:hover {
        color: var(--color-fleece-gold);
        text-decoration: none;
      }
      .footer-heading {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--color-fleece-gold);
        margin-bottom: 0.75rem;
      }
      .footer-grid ul {
        list-style: none;
      }
      .footer-grid li { margin-bottom: 0.5rem; }
      .footer-grid a { color: var(--color-starlight); font-size: 0.9rem; }
      .footer-grid a:hover { color: var(--color-parchment); }
      .footer-copy {
        font-size: 0.8rem;
        color: var(--color-slate);
        border-top: 1px solid rgba(255,255,255,0.08);
        padding-top: 1.5rem;
      }

      @media (max-width: 768px) {
        .top-bar { display: none; }
        .header-main {
          flex-direction: column;
          gap: 1rem;
        }
        .category-nav-inner {
          gap: 1.25rem;
          padding: 0.75rem 0;
        }
        .newsletter-inner {
          flex-direction: column;
          text-align: center;
        }
        .newsletter-form {
          flex-direction: column;
          width: 100%;
        }
        .newsletter-form input {
          width: 100%;
          border-right: 1px solid rgba(255,255,255,0.15);
          border-radius: 4px 4px 0 0;
        }
        .newsletter-form button {
          border-radius: 0 0 4px 4px;
        }
        .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
      }
    </style>
  </body>
</html>
