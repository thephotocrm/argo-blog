---
export const prerender = false;

import Dashboard from '../../components/admin/Dashboard.astro';
import { getTechSeoTasks, getLatestSerpSnapshot, getLatestContentGaps, getCompetitorChangelog } from '../../lib/data';
import { marked } from 'marked';

const techSeoTasks = getTechSeoTasks();
const serp = getLatestSerpSnapshot();
const gaps = getLatestContentGaps();
const competitors = getCompetitorChangelog();

const tasks = techSeoTasks.tasks || [];
const keywords = serp.keywords || [];
const gapsList = gaps.gaps || [];
const entries = competitors.entries || [];

// Load reports via glob
const mdFiles = import.meta.glob('../../data/synced/seo/reports/*.md', { query: '?raw', import: 'default', eager: true }) as Record<string, string>;
const jsonFiles = import.meta.glob('../../data/synced/seo/reports/*.json', { eager: true }) as Record<string, { default: any }>;

const reports = Object.entries(mdFiles)
  .map(([path, raw]) => {
    const name = path.split('/').pop() || '';
    return {
      name,
      displayName: name.replace(/\.md$/, '').replace(/-/g, ' '),
      html: raw ? marked(raw) : null,
    };
  })
  .sort((a, b) => b.name.localeCompare(a.name));

const jsonReports = Object.entries(jsonFiles)
  .map(([path, mod]) => {
    const name = path.split('/').pop() || '';
    return {
      name,
      displayName: name.replace(/\.json$/, '').replace(/-/g, ' '),
      data: (mod as any).default || mod,
    };
  })
  .sort((a, b) => b.name.localeCompare(a.name));
---

<Dashboard title="Monitoring" activePage="monitoring">
  <div class="page-header">
    <h1>Monitoring</h1>
    <p class="subtitle">{tasks.filter((t: any) => t.status !== 'done').length} open SEO issues &middot; {keywords.length} tracked keywords &middot; {reports.length + jsonReports.length} reports</p>
  </div>

  <!-- Tech SEO Checklist -->
  <section class="section">
    <h2 class="section-title">Tech SEO Issues</h2>
    <div class="checklist">
      {tasks.map((task: any) => (
        <div class:list={['check-item', { done: task.status === 'done' }]} data-id={task.id}>
          <button
            class:list={['check-toggle', { checked: task.status === 'done' }]}
            data-id={task.id}
            data-status={task.status}
          >
            {task.status === 'done' ? '&#10003;' : ''}
          </button>
          <div class="check-content">
            <span class="check-text">{task.issue}</span>
            <span class="check-cat">{task.category}</span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- SERP Positions -->
  {keywords.length > 0 && (
    <section class="section">
      <h2 class="section-title">SERP Positions</h2>
      <p class="section-note">Snapshot: {serp.date || 'latest'} &middot; {serp.search_engine || 'brave'}</p>
      <div class="table-scroll">
        <table class="data-table">
          <thead>
            <tr>
              <th>Keyword</th>
              <th>Priority</th>
              <th>Argo Position</th>
              <th>AI Overview</th>
              <th>Top 3 Competitors</th>
            </tr>
          </thead>
          <tbody>
            {keywords.map((kw: any) => (
              <tr>
                <td class="mono">{kw.keyword}</td>
                <td><span class:list={['badge', `priority-${kw.priority}`]}>{kw.priority}</span></td>
                <td class:list={['position', { 'pos-found': kw.argo_position }]}>
                  {kw.argo_position || 'Not found'}
                </td>
                <td>
                  {kw.ai_overview?.present ? (
                    <span class:list={['badge', kw.ai_overview.argo_cited ? 'cited' : 'not-cited']}>
                      {kw.ai_overview.argo_cited ? 'Cited' : 'Present'}
                    </span>
                  ) : <span class="badge none">None</span>}
                </td>
                <td class="competitors-cell">
                  {(kw.top_results || []).slice(0, 3).map((r: any) => (
                    <div class="comp-row">
                      <span class="comp-pos">#{r.position}</span>
                      <a href={r.url} target="_blank" rel="noopener" class="comp-link" title={r.title}>
                        {r.title?.substring(0, 50)}{(r.title?.length || 0) > 50 ? '...' : ''}
                      </a>
                    </div>
                  ))}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}

  <!-- Content Gaps -->
  {gapsList.length > 0 && (
    <section class="section">
      <h2 class="section-title">Content Gaps ({gapsList.length})</h2>
      <div class="table-scroll">
        <table class="data-table">
          <thead>
            <tr><th>Topic</th><th>Volume</th><th>Difficulty</th><th>Priority</th><th>Competitors</th><th>Notes</th></tr>
          </thead>
          <tbody>
            {gapsList.map((gap: any) => (
              <tr>
                <td class="topic-cell">{gap.topic}</td>
                <td class="mono">{gap.estimated_volume}</td>
                <td><span class:list={['badge', `diff-${gap.difficulty}`]}>{gap.difficulty}</span></td>
                <td><span class:list={['badge', `priority-${gap.priority}`]}>{gap.priority}</span></td>
                <td class="mono small">{(gap.competitors_ranking || []).join(', ')}</td>
                <td class="notes-cell">{gap.notes?.substring(0, 80)}{(gap.notes?.length || 0) > 80 ? '...' : ''}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}

  <!-- Competitor Intelligence -->
  {entries.length > 0 && (
    <section class="section">
      <h2 class="section-title">Competitor Intelligence</h2>
      {entries.map((entry: any) => (
        <div class="competitor-block">
          <div class="competitor-header">
            <h3 class="competitor-name">{entry.competitor}</h3>
            <span class="competitor-date">{entry.date}</span>
          </div>
          <div class="changes-list">
            {(entry.changes || []).map((change: any) => (
              <div class="change-item">
                <span class:list={['change-type', `type-${change.type}`]}>{change.type}</span>
                <p class="change-desc">{change.description}</p>
                {change.strategic_note && (
                  <p class="strategic-note">{change.strategic_note}</p>
                )}
              </div>
            ))}
          </div>
        </div>
      ))}
    </section>
  )}

  <!-- Report navigation -->
  {(reports.length > 0 || jsonReports.length > 0) && (
    <section class="section">
      <h2 class="section-title">Reports</h2>
      <div class="report-nav">
        {reports.map((r) => (
          <a href={`#report-${r.name}`} class="report-link">{r.displayName}</a>
        ))}
        {jsonReports.map((r) => (
          <a href={`#report-${r.name}`} class="report-link">{r.displayName}</a>
        ))}
      </div>
    </section>
  )}

  <!-- Rendered markdown reports -->
  {reports.map((r) => (
    <section class="section report-section" id={`report-${r.name}`}>
      <h2 class="section-title">{r.displayName}</h2>
      {r.html ? (
        <div class="report-body" set:html={r.html} />
      ) : (
        <p class="empty">Could not load report</p>
      )}
    </section>
  ))}

  <!-- JSON reports -->
  {jsonReports.map((r) => (
    <section class="section report-section" id={`report-${r.name}`}>
      <h2 class="section-title">{r.displayName}</h2>
      {r.data ? (
        <pre class="json-block">{JSON.stringify(r.data, null, 2)}</pre>
      ) : (
        <p class="empty">Could not load report</p>
      )}
    </section>
  ))}
</Dashboard>

<script>
  document.querySelectorAll('.check-toggle').forEach(btn => {
    btn.addEventListener('click', async () => {
      const el = btn as HTMLElement;
      const id = el.dataset.id;
      const currentStatus = el.dataset.status;
      const newStatus = currentStatus === 'done' ? 'open' : 'done';

      const res = await fetch(`/api/tech-seo-tasks/${id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: newStatus })
      });

      if (res.ok) location.reload();
      else alert('Update failed');
    });
  });
</script>

<style>
  .page-header { margin-bottom: 1.5rem; }
  .page-header h1 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    color: var(--color-parchment);
  }
  .subtitle {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-slate);
    margin-top: 0.25rem;
  }
  .section { margin-bottom: 2.5rem; }
  .section-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--color-parchment);
    margin-bottom: 0.75rem;
  }
  .section-note {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-slate);
    margin-bottom: 0.75rem;
  }

  /* Checklist */
  .checklist { display: flex; flex-direction: column; gap: 0.4rem; }
  .check-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--color-deep-water);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 4px;
    padding: 0.6rem 0.75rem;
  }
  .check-item.done { opacity: 0.5; }
  .check-toggle {
    width: 22px;
    height: 22px;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 3px;
    background: transparent;
    color: #86efac;
    font-size: 0.75rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .check-toggle.checked {
    background: rgba(134,239,172,0.1);
    border-color: rgba(134,239,172,0.3);
  }
  .check-content { display: flex; align-items: center; gap: 0.5rem; flex: 1; }
  .check-text {
    font-size: 0.8rem;
    color: var(--color-starlight);
  }
  .check-item.done .check-text { text-decoration: line-through; }
  .check-cat {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-slate);
    background: rgba(107,114,128,0.1);
    padding: 0.1rem 0.35rem;
    border-radius: 2px;
  }

  /* SERP & tables */
  .table-scroll { overflow-x: auto; }
  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.75rem;
  }
  .data-table th {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-slate);
    text-align: left;
    padding: 0.5rem 0.6rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    white-space: nowrap;
  }
  .data-table td {
    padding: 0.4rem 0.6rem;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    color: var(--color-starlight);
    vertical-align: top;
  }
  .mono { font-family: var(--font-mono); font-size: 0.65rem; }
  .small { font-size: 0.6rem; }
  .position { font-family: var(--font-mono); font-size: 0.7rem; color: var(--color-slate); }
  .position.pos-found { color: #86efac; }
  .badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    padding: 0.1rem 0.4rem;
    border-radius: 2px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .badge.priority-high { background: rgba(201,162,39,0.15); color: var(--color-fleece-gold); }
  .badge.priority-medium { background: rgba(107,114,128,0.15); color: var(--color-slate); }
  .badge.priority-low { background: rgba(107,114,128,0.08); color: var(--color-slate); }
  .badge.diff-low { background: rgba(134,239,172,0.1); color: #86efac; }
  .badge.diff-medium { background: rgba(201,162,39,0.15); color: var(--color-fleece-gold); }
  .badge.diff-high { background: rgba(239,68,68,0.15); color: #ef4444; }
  .badge.cited { background: rgba(134,239,172,0.1); color: #86efac; }
  .badge.not-cited { background: rgba(201,162,39,0.15); color: var(--color-fleece-gold); }
  .badge.none { background: rgba(107,114,128,0.08); color: var(--color-slate); }
  .competitors-cell { min-width: 250px; }
  .comp-row {
    display: flex;
    gap: 0.35rem;
    align-items: baseline;
    margin-bottom: 0.15rem;
  }
  .comp-pos {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-slate);
    flex-shrink: 0;
  }
  .comp-link {
    font-size: 0.65rem;
    color: var(--color-compass-blue);
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .comp-link:hover { color: var(--color-parchment); }
  .topic-cell { min-width: 200px; font-weight: 500; }
  .notes-cell { font-size: 0.65rem; color: var(--color-slate); max-width: 300px; }

  /* Competitor blocks */
  .competitor-block {
    background: var(--color-deep-water);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 4px;
    padding: 1rem;
    margin-bottom: 0.75rem;
  }
  .competitor-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }
  .competitor-name {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-parchment);
  }
  .competitor-date {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-slate);
  }
  .changes-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .change-item {
    border-left: 2px solid rgba(255,255,255,0.06);
    padding-left: 0.75rem;
  }
  .change-type {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: inline-block;
    margin-bottom: 0.25rem;
  }
  .type-messaging { color: var(--color-compass-blue); }
  .type-pricing { color: var(--color-fleece-gold); }
  .type-content { color: #86efac; }
  .type-feature { color: var(--color-pale-gold); }
  .change-desc {
    font-size: 0.75rem;
    color: var(--color-starlight);
    line-height: 1.5;
  }
  .strategic-note {
    font-size: 0.7rem;
    color: var(--color-fleece-gold);
    background: rgba(201,162,39,0.08);
    padding: 0.4rem 0.6rem;
    border-radius: 3px;
    margin-top: 0.35rem;
    line-height: 1.4;
  }

  /* Report nav */
  .report-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .report-link {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-compass-blue);
    text-decoration: none;
    padding: 0.3rem 0.6rem;
    border: 1px solid rgba(74,111,165,0.2);
    border-radius: 3px;
  }
  .report-link:hover { background: rgba(74,111,165,0.1); }

  /* Report body */
  .report-section {
    background: var(--color-deep-water);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 4px;
    padding: 1.25rem;
  }
  .report-body {
    font-size: 0.8rem;
    line-height: 1.7;
    color: var(--color-starlight);
  }
  .report-body :global(h1),
  .report-body :global(h2),
  .report-body :global(h3) {
    font-family: var(--font-display);
    color: var(--color-parchment);
    font-weight: 400;
    margin: 1rem 0 0.5rem;
  }
  .report-body :global(h1) { font-size: 1.25rem; }
  .report-body :global(h2) { font-size: 1.1rem; }
  .report-body :global(h3) { font-size: 0.95rem; }
  .report-body :global(p) { margin-bottom: 0.75rem; }
  .report-body :global(ul),
  .report-body :global(ol) { padding-left: 1.25rem; margin-bottom: 0.75rem; }
  .report-body :global(li) { margin-bottom: 0.25rem; }
  .report-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    background: rgba(0,0,0,0.3);
    padding: 0.1rem 0.3rem;
    border-radius: 2px;
  }
  .report-body :global(pre) {
    background: rgba(0,0,0,0.3);
    padding: 0.75rem;
    border-radius: 3px;
    overflow-x: auto;
    margin-bottom: 0.75rem;
  }
  .report-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 0.75rem;
    font-size: 0.75rem;
  }
  .report-body :global(th),
  .report-body :global(td) {
    text-align: left;
    padding: 0.4rem 0.6rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .report-body :global(th) {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    color: var(--color-slate);
  }
  .report-body :global(strong) { color: var(--color-parchment); }
  .report-body :global(a) { color: var(--color-compass-blue); }

  .json-block {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    background: rgba(0,0,0,0.3);
    padding: 0.75rem;
    border-radius: 3px;
    overflow-x: auto;
    color: var(--color-starlight);
    max-height: 400px;
    overflow-y: auto;
  }
  .empty { color: var(--color-slate); font-size: 0.8rem; }
</style>
