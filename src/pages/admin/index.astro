---
export const prerender = false;

import Dashboard from '../../components/admin/Dashboard.astro';
import StatsCards from '../../components/admin/StatsCards.astro';
import AlertStrip from '../../components/admin/AlertStrip.astro';
import CronHeatmap from '../../components/admin/CronHeatmap.astro';
import ContentPipeline from '../../components/admin/ContentPipeline.astro';
import RankingTable from '../../components/admin/RankingTable.astro';
import TrafficChart from '../../components/admin/TrafficChart.astro';
import KeywordTable from '../../components/admin/KeywordTable.astro';

import keywordData from '../../data/seo/keyword-research.json';
import contentQueue from '../../data/seo/content-queue.json';

// Load dashboard JSON files
import alertsData from '../../data/seo/dashboard/alerts.json';
import cronStatusData from '../../data/seo/dashboard/cron-status.json';
import algoData from '../../data/seo/dashboard/algo-updates.json';
import distData from '../../data/seo/dashboard/distribution.json';
import siData from '../../data/seo/dashboard/self-improvement.json';

// Count published blog posts
import { getCollection } from 'astro:content';
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const publishedPosts = allPosts.length;

// Keyword summary
const keywords = keywordData.keywords;
const statusCounts = {
  not_started: keywords.filter(k => k.status === 'not_started').length,
  in_progress: keywords.filter(k => k.status === 'in_progress').length,
  published: keywords.filter(k => k.status === 'published').length,
};

// Fetch GSC data (server-side)
let gscData: any = null;
try {
  const gscUrl = new URL('/api/gsc', Astro.url.origin);
  const gscRes = await fetch(gscUrl);
  if (gscRes.ok) {
    gscData = await gscRes.json();
  }
} catch {}

// Fetch GA4 data (server-side)
let ga4Data: any = null;
try {
  const ga4Url = new URL('/api/ga4', Astro.url.origin);
  const ga4Res = await fetch(ga4Url);
  if (ga4Res.ok) {
    ga4Data = await ga4Res.json();
  }
} catch {}

// Compute SEO engine stats
const cronRuns = cronStatusData?.data?.runs || [];
const now = new Date();
const oneDayAgo = new Date(now.getTime() - 24 * 60 * 60 * 1000);
const recentRuns = cronRuns.filter((r: any) => r.timestamp && new Date(r.timestamp) > oneDayAgo);
const cronStatus = recentRuns.length > 0 ? {
  succeeded: recentRuns.filter((r: any) => r.status === 'success').length,
  total: recentRuns.length,
} : null;

const algoStatus = algoData?.data?.status === 'active_update' ? 'Update Detected'
  : algoData?.data?.status === 'monitoring' ? 'Monitoring'
  : algoData?.data?.status === 'normal' ? 'Normal'
  : null;

const distributionQueue = distData?.data?.funnel?.pending ?? null;
const systemHealth = siData?.data?.systemHealthScore ?? null;
---

<Dashboard title="Dashboard" activePage="overview">
  <div class="dashboard-header">
    <h1>SEO Dashboard</h1>
    <p class="last-updated">Data as of {keywordData.lastUpdated}</p>
  </div>

  <StatsCards
    gscTotals={gscData?.totals}
    ga4Totals={ga4Data?.totals}
    publishedPosts={publishedPosts}
    totalKeywords={keywords.length}
    systemHealth={systemHealth}
    cronStatus={cronStatus}
    algoStatus={algoStatus}
    distributionQueue={distributionQueue}
  />

  <AlertStrip alerts={alertsData?.data?.items} />

  <CronHeatmap runs={cronStatusData?.data?.runs} />

  <ContentPipeline
    statusCounts={statusCounts}
    contentItems={contentQueue.items}
  />

  <div class="two-col">
    <RankingTable
      queries={gscData?.topQueries}
      error={gscData?.error}
    />
    <TrafficChart
      topPages={ga4Data?.topPages}
      sources={ga4Data?.sources}
      error={ga4Data?.error}
    />
  </div>

  <KeywordTable keywords={keywords} />
</Dashboard>

<style>
  .dashboard-header {
    margin-bottom: 1.5rem;
  }
  .dashboard-header h1 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    color: var(--color-parchment);
    margin: 0;
  }
  .last-updated {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-slate);
    margin-top: 0.25rem;
  }
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  @media (max-width: 900px) {
    .two-col { grid-template-columns: 1fr; }
  }
</style>
