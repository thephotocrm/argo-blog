---
export const prerender = false;

import Dashboard from '../../components/admin/Dashboard.astro';
import StatsCards from '../../components/admin/StatsCards.astro';

import { getContentQueue, getAuthorityOutbox, getCreators, getCronJobs, getKeywordCandidates, getIndexingStatus, getGscHistory, getDirectorySubmissions, getLinkBuilding, getGrowthTasks, getDistributionStatus } from '../../lib/data';

import keywordData from '../../data/seo/keyword-research.json';

// Count published blog posts
import { getCollection } from 'astro:content';
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const publishedPosts = allPosts.length;

// Marketing pipeline data
const liveQueue = getContentQueue();
const outbox = getAuthorityOutbox();
const creators = getCreators();
const cronData = getCronJobs();
const candidates = getKeywordCandidates();
const indexingStatus = getIndexingStatus();
const gscHistory = getGscHistory();

const pendingReviews = (liveQueue.items || []).filter((i: any) => i.status === 'pending_review').length;
const pendingOutbox = (outbox.items || []).filter((i: any) => i.status === 'pending_review').length;
const noOutreach = (creators.creators || []).filter((c: any) => c.outreachStatus === 'qualified' && c.followUpCount === 0).length;
const unvalidated = (candidates.candidates || []).filter((c: any) => c.decision === null).length;
const cronJobs = cronData.jobs || [];
const cronErrors = cronJobs.filter((j: any) => j.state?.lastRunStatus === 'error').length;

const keywords = keywordData.keywords;

// Fetch GSC data (server-side)
let gscData: any = null;
try {
  const gscUrl = new URL('/api/gsc', Astro.url.origin);
  const gscRes = await fetch(gscUrl);
  if (gscRes.ok) {
    gscData = await gscRes.json();
  }
} catch {}

// Strategy page data
const dirData = getDirectorySubmissions();
const dirToSubmit = (dirData.items || []).filter((d: any) => d.status === 'not_started').length;
const linkData = getLinkBuilding();
const linkOpps = (linkData.items || []).filter((l: any) => l.status === 'found').length;
const growthData = getGrowthTasks();
const growthOpen = (growthData.tasks || []).filter((t: any) => t.status === 'open').length;
const distData = getDistributionStatus();
const needsCrossPost = (distData.posts || []).reduce((acc: number, p: any) => {
  return acc + Object.values(p.platforms).filter((pl: any) => (pl as any).status === 'not_posted').length;
}, 0);

const hasActions = pendingReviews > 0 || pendingOutbox > 0 || noOutreach > 0 || unvalidated > 0 || cronErrors > 0 || dirToSubmit > 0 || linkOpps > 0 || growthOpen > 0 || needsCrossPost > 0;
---

<Dashboard title="Dashboard" activePage="overview">
  <div class="dashboard-header">
    <h1>Command Center</h1>
    <p class="last-updated">Data as of {keywordData.lastUpdated}</p>
  </div>

  <!-- Action Queue -->
  <div class="action-bar">
    {hasActions ? (
      <>
        {pendingReviews > 0 && <a href="/admin/content" class="action-badge gold">{pendingReviews} posts to review</a>}
        {pendingOutbox > 0 && <a href="/admin/outreach" class="action-badge blue">{pendingOutbox} outreach drafts</a>}
        {noOutreach > 0 && <a href="/admin/outreach#creators" class="action-badge green">{noOutreach} creators need outreach</a>}
        {unvalidated > 0 && <a href="/admin/content#candidates" class="action-badge slate">{unvalidated} keyword candidates</a>}
        {cronErrors > 0 && <span class="action-badge red">{cronErrors} cron errors</span>}
        {dirToSubmit > 0 && <a href="/admin/strategy#directories" class="action-badge gold">{dirToSubmit} directories to submit</a>}
        {linkOpps > 0 && <a href="/admin/strategy#link-building" class="action-badge blue">{linkOpps} link opportunities</a>}
        {growthOpen > 0 && <a href="/admin/strategy#growth" class="action-badge slate">{growthOpen} growth tasks open</a>}
        {needsCrossPost > 0 && <a href="/admin/strategy#distribution" class="action-badge green">{needsCrossPost} posts need cross-posting</a>}
      </>
    ) : (
      <span class="action-badge all-clear">All clear</span>
    )}
  </div>

  <!-- Quick Stats -->
  <StatsCards
    gscTotals={gscData?.totals}
    publishedPosts={publishedPosts}
    totalKeywords={keywords.length}
  />

  <!-- Google Indexing + GSC Trends -->
  <div class="two-col" style="margin-bottom: 1.5rem;">
    <div class="indexing-card">
      <h2 class="section-title">Google Indexing</h2>
      {indexingStatus.total > 0 ? (
        <div class="indexing-body">
          <div class="indexing-stat-row">
            <div class="indexing-stat">
              <span class="indexing-num green">{indexingStatus.indexed}</span>
              <span class="indexing-label">Indexed</span>
            </div>
            <div class="indexing-stat">
              <span class="indexing-num gold">{indexingStatus.crawled_not_indexed}</span>
              <span class="indexing-label">Crawled</span>
            </div>
            <div class="indexing-stat">
              <span class="indexing-num slate">{indexingStatus.discovered_not_indexed}</span>
              <span class="indexing-label">Discovered</span>
            </div>
            <div class="indexing-stat">
              <span class="indexing-num">{indexingStatus.total}</span>
              <span class="indexing-label">Total</span>
            </div>
          </div>
          <div class="indexing-bar">
            <div class="bar-indexed" style={`width: ${(indexingStatus.indexed / indexingStatus.total) * 100}%`}></div>
            <div class="bar-crawled" style={`width: ${(indexingStatus.crawled_not_indexed / indexingStatus.total) * 100}%`}></div>
          </div>
          {indexingStatus.pages.filter((p: any) => p.verdict !== 'PASS').length > 0 && (
            <details class="not-indexed-list">
              <summary>{indexingStatus.total - indexingStatus.indexed} not yet indexed</summary>
              <ul>
                {indexingStatus.pages.filter((p: any) => p.verdict !== 'PASS').map((p: any) => (
                  <li>
                    <span class="page-url">{p.url.replace('https://blog.argostudio.co', '')}</span>
                    <span class="page-state">{p.coverageState}</span>
                  </li>
                ))}
              </ul>
            </details>
          )}
          {indexingStatus.date && <div class="card-date">Updated {indexingStatus.date}</div>}
        </div>
      ) : (
        <div class="no-data">No indexing data yet — run gsc-indexing-check.sh</div>
      )}
    </div>

    <div class="gsc-trends-card">
      <h2 class="section-title">GSC Trends</h2>
      {gscHistory.dailyTotals && gscHistory.dailyTotals.length > 0 ? (
        <div class="trends-body">
          {(() => {
            const totals = gscHistory.dailyTotals;
            const latest = totals[totals.length - 1];
            const prev = totals.length > 1 ? totals[totals.length - 2] : null;
            const clickDelta = prev ? latest.clicks - prev.clicks : 0;
            const impDelta = prev ? latest.impressions - prev.impressions : 0;
            return (
              <div class="trend-stats">
                <div class="trend-stat">
                  <span class="trend-num">{latest.clicks}</span>
                  <span class="trend-label">Clicks</span>
                  {prev && <span class:list={['trend-delta', { 'delta-up': clickDelta > 0, 'delta-down': clickDelta < 0 }]}>{clickDelta > 0 ? '+' : ''}{clickDelta}</span>}
                </div>
                <div class="trend-stat">
                  <span class="trend-num">{latest.impressions}</span>
                  <span class="trend-label">Impressions</span>
                  {prev && <span class:list={['trend-delta', { 'delta-up': impDelta > 0, 'delta-down': impDelta < 0 }]}>{impDelta > 0 ? '+' : ''}{impDelta}</span>}
                </div>
                <div class="trend-stat">
                  <span class="trend-num">{latest.avgPosition || '—'}</span>
                  <span class="trend-label">Avg Position</span>
                </div>
              </div>
            );
          })()}
          <div class="sparkline">
            {gscHistory.dailyTotals.map((d: any, i: number) => {
              const max = Math.max(...gscHistory.dailyTotals.map((t: any) => t.impressions), 1);
              const height = Math.max((d.impressions / max) * 32, 2);
              return <div class="spark-bar" style={`height: ${height}px`} title={`${d.date}: ${d.impressions} imp, ${d.clicks} clicks`}></div>;
            })}
          </div>
          {gscHistory.lastUpdated && <div class="card-date">Updated {gscHistory.lastUpdated}</div>}
        </div>
      ) : (
        <div class="no-data">No GSC history yet — run gsc-daily-snapshot.sh</div>
      )}
    </div>
  </div>

  <!-- Creator Pipeline Funnel -->
  <div class="pipeline-funnel">
    <h2 class="section-title">Creator Pipeline</h2>
    <div class="funnel-stages">
      {(() => {
        const c = creators.creators || [];
        const stages = [
          { name: 'Discovered', count: c.length },
          { name: 'Qualified', count: c.filter((x: any) => x.outreachStatus === 'qualified' || x.outreachStatus === 'outreach_sent' || x.outreachStatus === 'converted').length },
          { name: 'Outreach Sent', count: c.filter((x: any) => x.outreachStatus === 'outreach_sent' || x.outreachStatus === 'converted').length },
          { name: 'Converted', count: c.filter((x: any) => x.outreachStatus === 'converted').length },
        ];
        return stages.map((s) => (
          <div class="funnel-stage">
            <div class="funnel-count">{s.count}</div>
            <div class="funnel-label">{s.name}</div>
          </div>
        ));
      })()}
    </div>
  </div>

  <!-- Cron Jobs -->
  <div class="cron-grid">
    <h2 class="section-title">Cron Jobs</h2>
    <div class="cron-cards">
      {cronJobs.map((job: any) => {
        const st = job.state || {};
        const isOk = st.lastRunStatus === 'ok';
        const isErr = st.lastRunStatus === 'error';
        const lastRun = st.lastRunAtMs ? new Date(st.lastRunAtMs).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : 'Never';
        const nextRun = st.nextRunAtMs ? new Date(st.nextRunAtMs).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : '—';
        return (
          <div class:list={['cron-card', { 'cron-ok': isOk, 'cron-err': isErr }]}>
            <div class="cron-name">{job.name}</div>
            <div class="cron-status">{isOk ? 'OK' : isErr ? 'ERROR' : st.lastRunStatus || 'unknown'}</div>
            <div class="cron-meta">Last: {lastRun}</div>
            <div class="cron-meta">Next: {nextRun}</div>
          </div>
        );
      })}
    </div>
  </div>
</Dashboard>

<style>
  .dashboard-header { margin-bottom: 1.5rem; }
  .dashboard-header h1 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    color: var(--color-parchment);
    margin: 0;
  }
  .last-updated {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-slate);
    margin-top: 0.25rem;
  }
  .action-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }
  .action-badge {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.35rem 0.75rem;
    border-radius: 3px;
    text-decoration: none;
  }
  .action-badge.gold { background: rgba(201,162,39,0.15); color: var(--color-fleece-gold); }
  .action-badge.blue { background: rgba(74,111,165,0.15); color: var(--color-compass-blue); }
  .action-badge.green { background: rgba(134,239,172,0.1); color: #86efac; }
  .action-badge.slate { background: rgba(107,114,128,0.15); color: var(--color-slate); }
  .action-badge.red { background: rgba(239,68,68,0.15); color: #ef4444; }
  .action-badge.all-clear { background: rgba(134,239,172,0.08); color: #86efac; }
  .section-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--color-parchment);
    margin-bottom: 0.75rem;
  }
  .cron-grid { margin-bottom: 2rem; }
  .cron-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.5rem;
  }
  .cron-card {
    background: var(--color-deep-water);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 4px;
    padding: 0.6rem 0.75rem;
  }
  .cron-card.cron-ok { border-left: 3px solid #86efac; }
  .cron-card.cron-err { border-left: 3px solid #ef4444; }
  .cron-name {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-parchment);
    margin-bottom: 0.25rem;
    word-break: break-all;
  }
  .cron-status {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }
  .cron-ok .cron-status { color: #86efac; }
  .cron-err .cron-status { color: #ef4444; }
  .cron-meta {
    font-size: 0.6rem;
    color: var(--color-slate);
  }
  .pipeline-funnel { margin-bottom: 2rem; }
  .funnel-stages {
    display: flex;
    gap: 1rem;
  }
  .funnel-stage {
    flex: 1;
    background: var(--color-deep-water);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 4px;
    padding: 1rem;
    text-align: center;
  }
  .funnel-count {
    font-family: var(--font-display);
    font-size: 1.75rem;
    color: var(--color-fleece-gold);
  }
  .funnel-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-slate);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  /* Indexing card */
  .indexing-card, .gsc-trends-card {
    background: var(--color-deep-water);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 4px;
    padding: 1rem 1.25rem;
  }
  .indexing-body, .trends-body { margin-top: 0.5rem; }
  .indexing-stat-row {
    display: flex;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  .indexing-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
  }
  .indexing-num {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-parchment);
  }
  .indexing-num.green { color: #86efac; }
  .indexing-num.gold { color: var(--color-fleece-gold); }
  .indexing-num.slate { color: var(--color-slate); }
  .indexing-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-slate);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .indexing-bar {
    height: 6px;
    background: rgba(255,255,255,0.06);
    border-radius: 3px;
    display: flex;
    overflow: hidden;
    margin-bottom: 0.75rem;
  }
  .bar-indexed { background: #86efac; }
  .bar-crawled { background: var(--color-fleece-gold); }
  .not-indexed-list {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-slate);
  }
  .not-indexed-list summary {
    cursor: pointer;
    margin-bottom: 0.5rem;
  }
  .not-indexed-list ul {
    list-style: none;
    padding: 0;
    max-height: 150px;
    overflow-y: auto;
  }
  .not-indexed-list li {
    display: flex;
    justify-content: space-between;
    padding: 0.2rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.03);
  }
  .page-url {
    color: var(--color-parchment);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 60%;
  }
  .page-state { color: var(--color-slate); }

  /* GSC trends card */
  .trend-stats {
    display: flex;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  .trend-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
  }
  .trend-num {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-parchment);
  }
  .trend-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-slate);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .trend-delta {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-slate);
  }
  .delta-up { color: #86efac; }
  .delta-down { color: #ef4444; }
  .sparkline {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 36px;
    margin-bottom: 0.5rem;
  }
  .spark-bar {
    flex: 1;
    background: var(--color-compass-blue);
    border-radius: 1px;
    min-width: 3px;
  }
  .card-date {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-slate);
    margin-top: 0.5rem;
  }
  .no-data {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-slate);
    padding: 1rem 0;
  }

  @media (max-width: 900px) {
    .two-col { grid-template-columns: 1fr; }
    .funnel-stages { flex-wrap: wrap; }
  }
</style>
