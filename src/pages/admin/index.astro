---
export const prerender = false;

import Dashboard from '../../components/admin/Dashboard.astro';
import StatsCards from '../../components/admin/StatsCards.astro';

import { getContentQueueLive, getAuthorityOutboxLive, getCreatorsLive, getCronJobs, getKeywordCandidatesLive, getIndexingStatus, getGscHistory, getDirectorySubmissions, getLinkBuilding, getGrowthTasks, getDistributionStatus } from '../../lib/data';

import keywordData from '../../data/seo/keyword-research.json';

// Count published blog posts
import { getCollection } from 'astro:content';
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const publishedPosts = allPosts.length;

// Marketing pipeline data (live from GitHub for writable data)
const liveQueue = await getContentQueueLive();
const outbox = await getAuthorityOutboxLive();
const creators = await getCreatorsLive();
const cronData = getCronJobs();
const candidates = await getKeywordCandidatesLive();
const indexingStatus = getIndexingStatus();
const gscHistory = getGscHistory();

const pendingReviews = (liveQueue.items || []).filter((i: any) => i.status === 'pending_review').length;
const pendingOutbox = (outbox.items || []).filter((i: any) => i.status === 'pending_review').length;
const noOutreach = (creators.creators || []).filter((c: any) => c.outreachStatus === 'qualified' && c.followUpCount === 0).length;
const unvalidated = (candidates.candidates || []).filter((c: any) => c.decision === null).length;
const cronJobs = cronData.jobs || [];
const cronErrors = cronJobs.filter((j: any) => j.state?.lastRunStatus === 'error').length;

const keywords = keywordData.keywords;

// Fetch GSC data (server-side)
let gscData: any = null;
try {
  const gscUrl = new URL('/api/gsc', Astro.url.origin);
  const gscRes = await fetch(gscUrl);
  if (gscRes.ok) {
    gscData = await gscRes.json();
  }
} catch {}

// Strategy page data
const dirData = getDirectorySubmissions();
const dirToSubmit = (dirData.items || []).filter((d: any) => d.status === 'not_started').length;
const linkData = getLinkBuilding();
const linkOpps = (linkData.items || []).filter((l: any) => l.status === 'found').length;
const growthData = getGrowthTasks();
const growthOpen = (growthData.tasks || []).filter((t: any) => t.status === 'open').length;
const distData = getDistributionStatus();
const needsCrossPost = (distData.posts || []).reduce((acc: number, p: any) => {
  return acc + Object.values(p.platforms).filter((pl: any) => (pl as any).status === 'not_posted').length;
}, 0);

const hasActions = pendingReviews > 0 || pendingOutbox > 0 || noOutreach > 0 || unvalidated > 0 || cronErrors > 0 || dirToSubmit > 0 || linkOpps > 0 || growthOpen > 0 || needsCrossPost > 0;
---

<Dashboard title="Dashboard" activePage="overview">
  <!-- Page Title + Breadcrumb -->
  <div class="page-header">
    <h1 class="page-title">Dashboard</h1>
    <nav class="breadcrumb">
      <a href="/admin" class="breadcrumb-link">Home</a>
      <span class="breadcrumb-sep">/</span>
      <span class="breadcrumb-current">Dashboard</span>
    </nav>
  </div>

  <!-- Top Stat Cards Row -->
  <div class="stat-cards-row">
    <!-- Card 1: Published Posts -->
    <div class="w-stat-card">
      <div class="w-stat-content">
        <span class="w-stat-label">Published Posts</span>
        <span class="w-stat-value">{publishedPosts}</span>
        <span class="w-stat-sub">Blog articles</span>
      </div>
      <div class="w-stat-chart area-chart-green"></div>
    </div>

    <!-- Card 2: Google Indexing (donut) -->
    <div class="w-stat-card">
      <div class="w-stat-content">
        <span class="w-stat-label">Google Indexing</span>
        <span class="w-stat-value">{indexingStatus.total > 0 ? indexingStatus.indexed : '--'}<span class="w-stat-of">/{indexingStatus.total || '--'}</span></span>
      </div>
      {indexingStatus.total > 0 ? (
        <div class="donut-wrap">
          <div
            class="donut"
            style={`background: conic-gradient(#3ac977 0% ${(indexingStatus.indexed / indexingStatus.total) * 100}%, #18a594 ${(indexingStatus.indexed / indexingStatus.total) * 100}% ${((indexingStatus.indexed + indexingStatus.crawled_not_indexed) / indexingStatus.total) * 100}%, #e6e6e6 ${((indexingStatus.indexed + indexingStatus.crawled_not_indexed) / indexingStatus.total) * 100}% 100%);`}
          >
            <div class="donut-hole"></div>
          </div>
          <div class="donut-legend">
            <span class="legend-dot" style="background:#3ac977"></span> Indexed
            <span class="legend-dot" style="background:#18a594; margin-left:0.5rem"></span> Crawled
            <span class="legend-dot" style="background:#e6e6e6; margin-left:0.5rem"></span> Discovered
          </div>
        </div>
      ) : (
        <div class="w-stat-chart area-chart-muted"></div>
      )}
    </div>

    <!-- Card 3: GSC Clicks -->
    <div class="w-stat-card">
      <div class="w-stat-content">
        <span class="w-stat-label">GSC Clicks</span>
        <span class="w-stat-value">{gscData?.totals ? gscData.totals.clicks.toLocaleString() : '--'}</span>
        {gscHistory.dailyTotals && gscHistory.dailyTotals.length > 1 && (() => {
          const totals = gscHistory.dailyTotals;
          const latest = totals[totals.length - 1];
          const prev = totals[totals.length - 2];
          const delta = latest.clicks - prev.clicks;
          return <span class:list={['w-stat-delta', { 'delta-up': delta > 0, 'delta-down': delta < 0 }]}>{delta > 0 ? '+' : ''}{delta} vs prev</span>;
        })()}
      </div>
      <div class="w-stat-chart area-chart-blue"></div>
    </div>

    <!-- Card 4: Tasks Pending -->
    <div class="w-stat-card">
      <div class="w-stat-content">
        <span class="w-stat-label">Tasks Pending</span>
        {(() => {
          const totalActions = pendingReviews + pendingOutbox + noOutreach + unvalidated + dirToSubmit + linkOpps + growthOpen + needsCrossPost + cronErrors;
          return (
            <>
              <span class="w-stat-value">{totalActions}</span>
              <div class="w-task-progress">
                <div class="task-progress-bar">
                  <div class="task-progress-fill" style={`width: ${totalActions > 0 ? Math.max(5, 100 - (totalActions / (totalActions + 5)) * 100) : 100}%`}></div>
                </div>
                <span class="task-progress-text">{totalActions === 0 ? 'All clear' : `${totalActions} action${totalActions !== 1 ? 's' : ''} needed`}</span>
              </div>
            </>
          );
        })()}
      </div>
      <div class="w-stat-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9,11 12,14 22,4" /><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" />
        </svg>
      </div>
    </div>
  </div>

  <!-- GSC Performance Overview (full width) -->
  <div class="card gsc-overview-card">
    <div class="card-header">
      <h2 class="card-title">GSC Performance Overview</h2>
      <div class="card-tabs">
        <button class="card-tab active">Week</button>
        <button class="card-tab">Month</button>
        <button class="card-tab">Year</button>
      </div>
    </div>
    {gscHistory.dailyTotals && gscHistory.dailyTotals.length > 0 ? (
      <div class="gsc-overview-body">
        <div class="sparkline-lg">
          {gscHistory.dailyTotals.map((d: any) => {
            const max = Math.max(...gscHistory.dailyTotals.map((t: any) => t.impressions), 1);
            const height = Math.max((d.impressions / max) * 100, 3);
            return (
              <div class="spark-col" title={`${d.date}: ${d.impressions} imp, ${d.clicks} clicks`}>
                <div class="spark-bar-lg" style={`height: ${height}%`}></div>
                <span class="spark-label">{d.date?.slice(5)}</span>
              </div>
            );
          })}
        </div>
        <div class="gsc-bottom-stats">
          {(() => {
            const totals = gscHistory.dailyTotals;
            const latest = totals[totals.length - 1];
            const prev = totals.length > 1 ? totals[totals.length - 2] : null;
            const clickDelta = prev ? latest.clicks - prev.clicks : 0;
            return (
              <>
                <div class="gsc-bottom-stat">
                  <span class="gsc-b-label">Clicks</span>
                  <span class="gsc-b-value">{latest.clicks}</span>
                </div>
                <div class="gsc-bottom-stat">
                  <span class="gsc-b-label">Impressions</span>
                  <span class="gsc-b-value">{latest.impressions}</span>
                </div>
                <div class="gsc-bottom-stat">
                  <span class="gsc-b-label">Avg Position</span>
                  <span class="gsc-b-value">{latest.avgPosition || '--'}</span>
                </div>
                <div class="gsc-bottom-stat">
                  <span class="gsc-b-label">Click Delta</span>
                  <span class:list={['gsc-b-value', { 'delta-up': clickDelta > 0, 'delta-down': clickDelta < 0 }]}>{clickDelta > 0 ? '+' : ''}{clickDelta}</span>
                </div>
              </>
            );
          })()}
        </div>
        {gscHistory.lastUpdated && <div class="card-date">Updated {gscHistory.lastUpdated}</div>}
      </div>
    ) : (
      <div class="no-data">No GSC history yet -- run gsc-daily-snapshot.sh</div>
    )}
  </div>

  <!-- Two Column: Action Queue + Creator Pipeline -->
  <div class="two-col">
    <!-- Action Queue -->
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">Action Queue</h2>
        <span class="card-count">{pendingReviews + pendingOutbox + noOutreach + unvalidated + cronErrors + dirToSubmit + linkOpps + growthOpen + needsCrossPost} items</span>
      </div>
      <div class="action-list">
        {hasActions ? (
          <>
            {pendingReviews > 0 && (
              <div class="action-item border-gold">
                <div class="action-text">
                  <span class="action-name">Posts to review</span>
                  <span class="action-count-badge">{pendingReviews}</span>
                </div>
                <a href="/admin/content" class="action-link-badge badge-gold">Content</a>
              </div>
            )}
            {pendingOutbox > 0 && (
              <div class="action-item border-blue">
                <div class="action-text">
                  <span class="action-name">Outreach drafts</span>
                  <span class="action-count-badge">{pendingOutbox}</span>
                </div>
                <a href="/admin/outreach" class="action-link-badge badge-blue">Outreach</a>
              </div>
            )}
            {noOutreach > 0 && (
              <div class="action-item border-green">
                <div class="action-text">
                  <span class="action-name">Creators need outreach</span>
                  <span class="action-count-badge">{noOutreach}</span>
                </div>
                <a href="/admin/outreach#creators" class="action-link-badge badge-green">Outreach</a>
              </div>
            )}
            {unvalidated > 0 && (
              <div class="action-item border-slate">
                <div class="action-text">
                  <span class="action-name">Keyword candidates</span>
                  <span class="action-count-badge">{unvalidated}</span>
                </div>
                <a href="/admin/content#candidates" class="action-link-badge badge-slate">Content</a>
              </div>
            )}
            {cronErrors > 0 && (
              <div class="action-item border-red">
                <div class="action-text">
                  <span class="action-name">Cron errors</span>
                  <span class="action-count-badge">{cronErrors}</span>
                </div>
                <span class="action-link-badge badge-red">System</span>
              </div>
            )}
            {dirToSubmit > 0 && (
              <div class="action-item border-gold">
                <div class="action-text">
                  <span class="action-name">Directories to submit</span>
                  <span class="action-count-badge">{dirToSubmit}</span>
                </div>
                <a href="/admin/strategy#directories" class="action-link-badge badge-gold">Strategy</a>
              </div>
            )}
            {linkOpps > 0 && (
              <div class="action-item border-blue">
                <div class="action-text">
                  <span class="action-name">Link opportunities</span>
                  <span class="action-count-badge">{linkOpps}</span>
                </div>
                <a href="/admin/strategy#link-building" class="action-link-badge badge-blue">Strategy</a>
              </div>
            )}
            {growthOpen > 0 && (
              <div class="action-item border-slate">
                <div class="action-text">
                  <span class="action-name">Growth tasks open</span>
                  <span class="action-count-badge">{growthOpen}</span>
                </div>
                <a href="/admin/strategy#growth" class="action-link-badge badge-slate">Strategy</a>
              </div>
            )}
            {needsCrossPost > 0 && (
              <div class="action-item border-green">
                <div class="action-text">
                  <span class="action-name">Posts need cross-posting</span>
                  <span class="action-count-badge">{needsCrossPost}</span>
                </div>
                <a href="/admin/strategy#distribution" class="action-link-badge badge-green">Strategy</a>
              </div>
            )}
          </>
        ) : (
          <div class="action-item border-green">
            <div class="action-text">
              <span class="action-name" style="color: var(--color-success)">All clear -- no actions needed</span>
            </div>
          </div>
        )}
      </div>
    </div>

    <!-- Creator Pipeline -->
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">Creator Pipeline</h2>
      </div>
      <div class="pipeline-body">
        {(() => {
          const c = creators.creators || [];
          const stages = [
            { name: 'Discovered', count: c.length, color: '#6c757d' },
            { name: 'Qualified', count: c.filter((x: any) => x.outreachStatus === 'qualified' || x.outreachStatus === 'outreach_sent' || x.outreachStatus === 'converted').length, color: '#0d99ff' },
            { name: 'Outreach Sent', count: c.filter((x: any) => x.outreachStatus === 'outreach_sent' || x.outreachStatus === 'converted').length, color: '#18a594' },
            { name: 'Converted', count: c.filter((x: any) => x.outreachStatus === 'converted').length, color: '#3ac977' },
          ];
          const maxCount = Math.max(...stages.map(s => s.count), 1);
          return (
            <div class="funnel-bars">
              {stages.map((s) => (
                <div class="funnel-row">
                  <div class="funnel-row-label">
                    <span class="funnel-name">{s.name}</span>
                    <span class="funnel-num">{s.count}</span>
                  </div>
                  <div class="funnel-bar-track">
                    <div class="funnel-bar-fill" style={`width: ${Math.max((s.count / maxCount) * 100, 4)}%; background: ${s.color};`}></div>
                  </div>
                </div>
              ))}
            </div>
          );
        })()}
      </div>
    </div>
  </div>

  <!-- Cron Jobs Grid -->
  <div class="card cron-section">
    <div class="card-header">
      <h2 class="card-title">Cron Jobs</h2>
      <span class="card-count">{cronJobs.length} jobs{cronErrors > 0 ? ` / ${cronErrors} errors` : ''}</span>
    </div>
    <div class="cron-cards">
      {cronJobs.map((job: any) => {
        const st = job.state || {};
        const isOk = st.lastRunStatus === 'ok';
        const isErr = st.lastRunStatus === 'error';
        const lastRun = st.lastRunAtMs ? new Date(st.lastRunAtMs).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : 'Never';
        const nextRun = st.nextRunAtMs ? new Date(st.nextRunAtMs).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : '--';
        return (
          <div class:list={['cron-card', { 'cron-ok': isOk, 'cron-err': isErr }]}>
            <div class="cron-top">
              <div class="cron-name">{job.name}</div>
              <span class:list={['cron-status-badge', { 'status-ok': isOk, 'status-err': isErr }]}>
                {isOk ? 'OK' : isErr ? 'ERROR' : st.lastRunStatus || 'unknown'}
              </span>
            </div>
            <div class="cron-meta">Last: {lastRun}</div>
            <div class="cron-meta">Next: {nextRun}</div>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Data timestamp -->
  <div class="page-footer">
    Data as of {keywordData.lastUpdated}
  </div>
</Dashboard>

<style>
  /* Page Header */
  .page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-parchment);
  }
  .breadcrumb {
    font-size: 0.75rem;
    color: var(--color-slate);
  }
  .breadcrumb-link {
    color: var(--primary);
    text-decoration: none;
  }
  .breadcrumb-link:hover { text-decoration: underline; }
  .breadcrumb-sep { margin: 0 0.35rem; color: var(--color-slate); }
  .breadcrumb-current { color: var(--color-slate); }

  /* Card Base */
  .card {
    background: #fff;
    border-radius: 0.75rem;
    box-shadow: 0 0 13px 0 rgba(82, 63, 105, 0.05);
    border: 0;
    padding: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .card-title {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-parchment);
  }
  .card-count {
    font-size: 0.7rem;
    color: var(--color-slate);
    background: var(--color-frost);
    padding: 0.2rem 0.6rem;
    border-radius: 1rem;
  }
  .card-date {
    font-size: 0.65rem;
    color: var(--color-slate);
    margin-top: 0.75rem;
  }
  .no-data {
    font-size: 0.75rem;
    color: var(--color-slate);
    padding: 1.5rem 0;
  }

  /* Top Stat Cards Row */
  .stat-cards-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .w-stat-card {
    background: #fff;
    border-radius: 0.75rem;
    box-shadow: 0 0 13px 0 rgba(82, 63, 105, 0.05);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    position: relative;
    overflow: hidden;
  }
  .w-stat-content {
    position: relative;
    z-index: 1;
  }
  .w-stat-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-slate);
    margin-bottom: 0.25rem;
  }
  .w-stat-value {
    display: block;
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-parchment);
    line-height: 1.2;
  }
  .w-stat-of {
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-slate);
  }
  .w-stat-sub {
    display: block;
    font-size: 0.65rem;
    color: var(--color-slate);
    margin-top: 0.15rem;
  }
  .w-stat-delta {
    display: inline-block;
    font-size: 0.7rem;
    margin-top: 0.25rem;
    color: var(--color-slate);
  }
  .w-stat-icon {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    opacity: 0.5;
  }

  /* Mini area chart placeholders */
  .w-stat-chart {
    height: 40px;
    border-radius: 0.375rem;
  }
  .area-chart-green {
    background: linear-gradient(180deg, rgba(58,201,119,0.2) 0%, rgba(58,201,119,0.02) 100%);
    border-bottom: 2px solid rgba(58,201,119,0.5);
  }
  .area-chart-blue {
    background: linear-gradient(180deg, rgba(13,153,255,0.2) 0%, rgba(13,153,255,0.02) 100%);
    border-bottom: 2px solid rgba(13,153,255,0.5);
  }
  .area-chart-muted {
    background: linear-gradient(180deg, rgba(108,117,125,0.1) 0%, rgba(108,117,125,0.02) 100%);
    border-bottom: 2px solid rgba(108,117,125,0.2);
  }

  /* Donut chart */
  .donut-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }
  .donut {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .donut-hole {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #fff;
  }
  .donut-legend {
    display: flex;
    align-items: center;
    font-size: 0.55rem;
    color: var(--color-slate);
    gap: 0.2rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .legend-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
  }

  /* Delta colors */
  .delta-up { color: var(--color-success) !important; }
  .delta-down { color: var(--color-danger) !important; }

  /* Task progress */
  .w-task-progress { margin-top: 0.5rem; }
  .task-progress-bar {
    height: 6px;
    background: var(--color-border-light);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 0.3rem;
  }
  .task-progress-fill {
    height: 100%;
    background: var(--primary);
    border-radius: 3px;
    transition: width 0.3s;
  }
  .task-progress-text {
    font-size: 0.6rem;
    color: var(--color-slate);
  }

  /* GSC Overview Card */
  .gsc-overview-card {
    margin-bottom: 1.5rem;
  }
  .card-tabs {
    display: flex;
    gap: 0;
    background: var(--color-frost);
    border-radius: 0.5rem;
    overflow: hidden;
  }
  .card-tab {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.35rem 0.85rem;
    border: none;
    background: transparent;
    color: var(--color-slate);
    cursor: pointer;
    transition: all 0.15s;
  }
  .card-tab.active {
    background: var(--primary);
    color: #fff;
    border-radius: 0.5rem;
  }
  .sparkline-lg {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 120px;
    padding: 0.5rem 0;
  }
  .spark-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
    justify-content: flex-end;
  }
  .spark-bar-lg {
    width: 100%;
    max-width: 24px;
    background: linear-gradient(180deg, var(--primary) 0%, rgba(24,165,148,0.3) 100%);
    border-radius: 3px 3px 0 0;
    min-height: 3px;
    transition: height 0.2s;
  }
  .spark-col:hover .spark-bar-lg {
    background: var(--primary);
  }
  .spark-label {
    font-size: 0.5rem;
    color: var(--color-slate);
    margin-top: 0.3rem;
    white-space: nowrap;
  }
  .gsc-bottom-stats {
    display: flex;
    gap: 2rem;
