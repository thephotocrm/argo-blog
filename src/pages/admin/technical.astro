---
export const prerender = false;

import Dashboard from '../../components/admin/Dashboard.astro';
import AuditSummary from '../../components/admin/AuditSummary.astro';
import AlgoStatus from '../../components/admin/AlgoStatus.astro';

import auditData from '../../data/seo/dashboard/audit-summary.json';
import canData from '../../data/seo/dashboard/cannibalization.json';
import linksData from '../../data/seo/dashboard/internal-links.json';
import algoData from '../../data/seo/dashboard/algo-updates.json';

const audit = auditData?.data || {};
const algo = algoData?.data || {};
---

<Dashboard title="Technical" activePage="technical">
  <div class="dashboard-header">
    <h1>Technical</h1>
    <p class="last-updated">{auditData?.lastUpdated ? `Audit updated ${auditData.lastUpdated}` : 'Awaiting first data sync'}</p>
  </div>

  <AlgoStatus
    status={algo.status}
    volatilityScore={algo.volatilityScore}
    lastChecked={algo.lastChecked}
    activeUpdate={algo.activeUpdate}
  />

  <AuditSummary
    healthScore={audit.healthScore}
    issues={audit.issues}
    cwv={audit.cwv}
    cannibalization={canData?.data?.cases}
    internalLinks={linksData?.data}
  />
</Dashboard>

<style>
  .dashboard-header {
    margin-bottom: 1.5rem;
  }
  .dashboard-header h1 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    color: var(--color-parchment);
    margin: 0;
  }
  .last-updated {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-slate);
    margin-top: 0.25rem;
  }
</style>
