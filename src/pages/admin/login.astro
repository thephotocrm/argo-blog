---
export const prerender = false;

const error = Astro.url.searchParams.get('error');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin Login — Argo Studio</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'Poppins', sans-serif;
        background: #2c2c2c;
        color: #888888;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .login-card {
        background: #ffffff;
        border: 1px solid #e6e6e6;
        border-radius: 0.375rem;
        padding: 2.5rem;
        width: 100%;
        max-width: 380px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
      }
      .login-card h1 {
        font-size: 1.5rem;
        font-weight: 600;
        color: #374557;
        margin-bottom: 0.5rem;
      }
      .overline {
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #18a594;
        margin-bottom: 1.5rem;
        display: block;
      }
      .error {
        background: rgba(255, 94, 94, 0.1);
        border: 1px solid rgba(255, 94, 94, 0.3);
        color: #ff5e5e;
        font-size: 0.85rem;
        padding: 0.6rem 0.8rem;
        border-radius: 0.375rem;
        margin-bottom: 1rem;
      }
      label {
        font-size: 0.85rem;
        color: #6c757d;
        display: block;
        margin-bottom: 0.4rem;
        font-weight: 500;
      }
      input[type="password"] {
        width: 100%;
        padding: 0.6rem 0.8rem;
        background: #f5f5f5;
        border: 1px solid #e6e6e6;
        border-radius: 0.375rem;
        color: #374557;
        font-family: 'Poppins', sans-serif;
        font-size: 0.9rem;
        outline: none;
      }
      input[type="password"]:focus {
        border-color: #18a594;
        box-shadow: 0 0 0 3px rgba(24, 165, 148, 0.15);
      }
      button {
        width: 100%;
        margin-top: 1.25rem;
        padding: 0.65rem;
        background: #18a594;
        color: #ffffff;
        border: none;
        border-radius: 0.375rem;
        font-family: 'Poppins', sans-serif;
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.15s;
      }
      button:hover { background: #159384; }
      .back-link {
        display: block;
        text-align: center;
        margin-top: 1.25rem;
        font-size: 0.8rem;
        color: #6c757d;
        text-decoration: none;
      }
      .back-link:hover { color: #374557; }
    </style>
  </head>
  <body>
    <div class="login-card">
      <span class="overline">Admin</span>
      <h1>Argo Studio</h1>
      {error && <p class="error">Invalid password. Try again.</p>}
      <form method="POST" action="/api/auth">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required autofocus />
        <button type="submit">Sign In</button>
      </form>
      <a href="/" class="back-link">Back to blog</a>
    </div>
  </body>
</html>
