<script>
  // Directory submissions
  document.querySelectorAll('.btn-submit-dir').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      const id = (btn as HTMLElement).dataset.id;
      const res = await fetch(`/api/directory-submissions/${id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'submitted', submittedAt: new Date().toISOString().split('T')[0] })
      });
      if (res.ok) location.reload();
      else alert('Update failed');
    });
  });

  document.querySelectorAll('.btn-live-dir').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      const id = (btn as HTMLElement).dataset.id;
      const listingUrl = prompt('Enter listing URL (optional):');
      const res = await fetch(`/api/directory-submissions/${id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'live', listingUrl: listingUrl || null })
      });
      if (res.ok) location.reload();
      else alert('Update failed');
    });
  });

  // Link building
  document.querySelectorAll('.btn-copy').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = (btn as HTMLElement).dataset.text || '';
      navigator.clipboard.writeText(text).then(() => {
        (btn as HTMLElement).textContent = 'Copied!';
        setTimeout(() => { (btn as HTMLElement).textContent = 'Copy Draft'; }, 1500);
      });
    });
  });

  async function updateLink(id: string, status: string) {
    const body: any = { status };
    if (status === 'contacted') body.contactedAt = new Date().toISOString().split('T')[0];
    if (status === 'won') body.wonAt = new Date().toISOString().split('T')[0];
    const res = await fetch(`/api/link-building/${id}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    if (res.ok) location.reload();
    else alert('Update failed');
  }

  document.querySelectorAll('.btn-link-contacted').forEach(btn => {
    btn.addEventListener('click', () => updateLink((btn as HTMLElement).dataset.id!, 'contacted'));
  });
  document.querySelectorAll('.btn-link-won').forEach(btn => {
    btn.addEventListener('click', () => updateLink((btn as HTMLElement).dataset.id!, 'won'));
  });
  document.querySelectorAll('.btn-link-lost').forEach(btn => {
    btn.addEventListener('click', () => updateLink((btn as HTMLElement).dataset.id!, 'lost'));
  });
  document.querySelectorAll('.btn-link-skip').forEach(btn => {
    btn.addEventListener('click', () => updateLink((btn as HTMLElement).dataset.id!, 'skipped'));
  });

  // Growth tasks
  document.querySelectorAll('.growth-check').forEach(cb => {
    cb.addEventListener('change', async () => {
      const id = (cb as HTMLInputElement).dataset.id;
      const newStatus = (cb as HTMLInputElement).checked ? 'done' : 'open';
      const res = await fetch(`/api/growth-tasks/${id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: newStatus })
      });
      if (res.ok) location.reload();
      else alert('Update failed');
    });
  });

  // Distribution toggle
  document.querySelectorAll('.btn-dist-toggle').forEach(btn => {
    btn.addEventListener('click', async () => {
      const slug = (btn as HTMLElement).dataset.slug;
      const platform = (btn as HTMLElement).dataset.platform;
      const url = prompt(`Enter ${platform} URL for this post (optional):`);
      const res = await fetch('/api/distribution-status', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug, platform, status: 'posted', url: url || null })
      });
      if (res.ok) location.reload();
      else alert('Update failed');
    });
  });

  // Copy blog URL buttons
  document.querySelectorAll('.btn-copy-url').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const url = (btn as HTMLElement).dataset.url || '';
      navigator.clipboard.writeText(url).then(() => {
        (btn as HTMLElement).textContent = '\u2713';
        setTimeout(() => { (btn as HTMLElement).textContent = '\u{1F4CB}'; }, 1500);
      });
    });
  });

  // Review solicitation
  document.querySelectorAll('.btn-review-contact').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = (btn as HTMLElement).dataset.id;
      const res = await fetch(`/api/review-solicitation/${id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'contacted' })
      });
      if (res.ok) location.reload();
      else alert('Update failed');
    });
  });

  document.querySelectorAll('.btn-review-posted').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = (btn as HTMLElement).dataset.id;
      const reviewUrl = prompt('Enter review URL:');
      const res = await fetch(`/api/review-solicitation/${id}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: 'review_posted', reviewPosted: true, reviewUrl })
      });
      if (res.ok) location.reload();
      else alert('Update failed');
    });
  });

  // Add contact
  document.getElementById('btn-add-contact')?.addEventListener('click', async () => {
    const name = prompt('Contact name:');
    if (!name) return;
    const email = prompt('Email (optional):') || '';
    const targetPlatform = prompt('Platform (G2 or Capterra):');
    if (!targetPlatform) return;

    const res = await fetch('/api/review-solicitation/add', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, email, targetPlatform })
    });
    if (res.ok) location.reload();
    else alert('Failed to add contact');
  });
</script>
