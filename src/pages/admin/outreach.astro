---
export const prerender = false;

import Dashboard from '../../components/admin/Dashboard.astro';
import { getAuthorityOutbox, getCreators, getDiscoveryState } from '../../lib/data';

const outbox = getAuthorityOutbox();
const items = outbox.items || [];
const redditPending = items.filter((i: any) => i.type === 'reddit_answer' && i.status === 'pending_review');
const haroPending = items.filter((i: any) => i.type === 'haro_pitch' && i.status === 'pending_review');
const completed = items.filter((i: any) => i.status !== 'pending_review');

const creatorsData = getCreators();
const discoveryState = getDiscoveryState();
const creators = creatorsData.creators || [];
const qualified = creators.filter((c: any) => c.outreachStatus === 'qualified');
const outreachSent = creators.filter((c: any) => c.outreachStatus === 'outreach_sent');
const converted = creators.filter((c: any) => c.outreachStatus === 'converted');
const noOutreach = qualified.filter((c: any) => c.followUpCount === 0);
---

<Dashboard title="Outreach" activePage="outreach">
  <div class="page-header">
    <h1>Outreach</h1>
    <p class="subtitle">{redditPending.length} Reddit drafts &middot; {haroPending.length} HARO pitches &middot; {noOutreach.length} creators need outreach</p>
  </div>

  <!-- Authority Outbox: Reddit -->
  {redditPending.length > 0 && (
    <section class="section">
      <h2 class="section-title">Reddit Answers</h2>
      <div class="outbox-list">
        {redditPending.map((item: any) => (
          <div class="outbox-card" data-id={item.id}>
            <div class="card-header">
              <span class="badge subreddit">{item.subreddit}</span>
              <span class="badge pending">Pending</span>
            </div>
            <h3 class="card-title">
              <a href={item.thread_url} target="_blank" rel="noopener" class="thread-link">{item.thread_title}</a>
            </h3>
            {item.mentions_argo && <span class="argo-tag">Mentions Argo</span>}
            {item.notes && <p class="card-notes">{item.notes}</p>}
            <div class="draft-box">
              <pre class="draft-text">{item.answer}</pre>
            </div>
            <div class="card-actions">
              <button class="btn btn-copy" data-text={item.answer}>Copy to Clipboard</button>
              <a href={item.thread_url} target="_blank" rel="noopener" class="btn btn-open">Open Thread</a>
              <button class="btn btn-posted" data-id={item.id}>Mark as Posted</button>
              <button class="btn btn-skip" data-id={item.id}>Skip</button>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Authority Outbox: HARO -->
  {haroPending.length > 0 && (
    <section class="section">
      <h2 class="section-title">HARO Pitches</h2>
      <div class="outbox-list">
        {haroPending.map((item: any) => (
          <div class="outbox-card" data-id={item.id}>
            <div class="card-header">
              <span class="badge haro">HARO</span>
              <span class="badge pending">Pending</span>
              {item.deadline && <span class="card-deadline">Deadline: {item.deadline}</span>}
            </div>
            <h3 class="card-title">{item.query_summary}</h3>
            {item.bio && <p class="card-bio">Bio: {item.bio}</p>}
            {item.notes && <p class="card-notes">{item.notes}</p>}
            <div class="draft-box">
              <pre class="draft-text">{item.pitch}</pre>
            </div>
            <div class="card-actions">
              <button class="btn btn-copy" data-text={item.pitch}>Copy Pitch</button>
              <button class="btn btn-sent" data-id={item.id}>Mark as Sent</button>
              <button class="btn btn-skip" data-id={item.id}>Skip</button>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Completed outbox items -->
  {completed.length > 0 && (
    <section class="section">
      <h2 class="section-title">Completed ({completed.length})</h2>
      <table class="data-table">
        <thead>
          <tr><th>Type</th><th>Title / Query</th><th>Status</th><th>Created</th></tr>
        </thead>
        <tbody>
          {completed.map((item: any) => (
            <tr>
              <td class="mono">{item.type}</td>
              <td>{item.thread_title || item.query_summary}</td>
              <td><span class:list={['badge', item.status]}>{item.status}</span></td>
              <td class="mono">{item.created?.split('T')[0]}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  )}

  <!-- Creator Pipeline -->
  <div id="creators">
    <h2 class="section-title" style="margin-top: 2rem;">Creator Pipeline</h2>

    <!-- Funnel -->
    <div class="funnel">
      <div class="funnel-stage">
        <div class="funnel-count">{creators.length}</div>
        <div class="funnel-label">Discovered</div>
      </div>
      <div class="funnel-arrow">&#8594;</div>
      <div class="funnel-stage">
        <div class="funnel-count">{qualified.length}</div>
        <div class="funnel-label">Qualified</div>
      </div>
      <div class="funnel-arrow">&#8594;</div>
      <div class="funnel-stage">
        <div class="funnel-count">{outreachSent.length}</div>
        <div class="funnel-label">Outreach Sent</div>
      </div>
      <div class="funnel-arrow">&#8594;</div>
      <div class="funnel-stage">
        <div class="funnel-count">{converted.length}</div>
        <div class="funnel-label">Converted</div>
      </div>
    </div>

    <!-- Discovery State -->
    {discoveryState.lastSession && (
      <div class="discovery-bar">
        <span>Last discovery: <strong>{discoveryState.lastSession.platform}</strong> on {discoveryState.lastSession.date}</span>
        <span class="sep">&middot;</span>
        <span>Next: <strong>{discoveryState.nextSession?.platform || '—'}</strong></span>
        {discoveryState.lastAttempt?.status === 'failed' && (
          <span class="discovery-warn">Last attempt failed: {discoveryState.lastAttempt.reason}</span>
        )}
      </div>
    )}

    <!-- Creator Cards -->
    <div class="creator-grid">
      {creators.sort((a: any, b: any) => (b.score || 0) - (a.score || 0)).map((creator: any) => (
        <div class="creator-card" data-id={creator.id}>
          <div class="card-top">
            <div class="avatar">{creator.displayName?.charAt(0) || '?'}</div>
            <div class="card-info">
              <h3 class="creator-name">
                <a href={creator.profileUrl} target="_blank" rel="noopener">{creator.displayName}</a>
              </h3>
              <div class="creator-handle">@{creator.handle} &middot; {creator.platform}</div>
            </div>
            <div class="score-badge" data-tier={creator.tier}>
              <div class="score-num">{creator.score}</div>
              <div class="score-label">{creator.tier}</div>
            </div>
          </div>

          <div class="creator-meta">
            <span>{creator.followers?.toLocaleString()} followers</span>
            {creator.location && <><span class="sep">&middot;</span><span>{creator.location}</span></>}
          </div>

          {creator.nicheTags && (
            <div class="tag-list">
              {creator.nicheTags.slice(0, 5).map((tag: string) => (
                <span class="niche-tag">{tag}</span>
              ))}
            </div>
          )}

          {creator.notes && <p class="creator-notes">{creator.notes}</p>}

          <div class="card-footer">
            <div class="status-row">
              <span class:list={['badge', creator.outreachStatus]}>{creator.outreachStatus.replace(/_/g, ' ')}</span>
              {creator.followUpCount > 0 && <span class="followup-count">{creator.followUpCount} follow-ups</span>}
            </div>
            <div class="card-actions">
              <a href={creator.profileUrl} target="_blank" rel="noopener" class="btn btn-profile">View Profile</a>
              {creator.outreachStatus === 'qualified' && creator.followUpCount === 0 && (
                <button class="btn btn-outreach" data-id={creator.id}>Draft Outreach</button>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  {items.length === 0 && creators.length === 0 && (
    <div class="empty-state">
      <p>No outreach items yet.</p>
    </div>
  )}
</Dashboard>

<script>
  // Copy to clipboard
  document.querySelectorAll('.btn-copy').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = (btn as HTMLElement).dataset.text || '';
      try {
        await navigator.clipboard.writeText(text);
        const el = btn as HTMLElement;
        const orig = el.textContent;
        el.textContent = 'Copied!';
        setTimeout(() => { el.textContent = orig; }, 1500);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        const el = btn as HTMLElement;
        const orig = el.textContent;
        el.textContent = 'Copied!';
        setTimeout(() => { el.textContent = orig; }, 1500);
      }
    });
  });

  // Authority outbox status updates
  async function updateOutbox(id: string, status: string) {
    const res = await fetch(`/api/authority-outbox/${encodeURIComponent(id)}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status })
    });
    if (res.ok) location.reload();
    else alert('Update failed');
  }

  document.querySelectorAll('.btn-posted').forEach(btn => {
    btn.addEventListener('click', () => updateOutbox((btn as HTMLElement).dataset.id!, 'posted'));
  });
  document.querySelectorAll('.btn-sent').forEach(btn => {
    btn.addEventListener('click', () => updateOutbox((btn as HTMLElement).dataset.id!, 'sent'));
  });
  document.querySelectorAll('.btn-skip').forEach(btn => {
    btn.addEventListener('click', () => updateOutbox((btn as HTMLElement).dataset.id!, 'skipped'));
  });

  // Creator outreach
  document.querySelectorAll('.btn-outreach').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = (btn as HTMLElement).dataset.id!;
      const res = await fetch(`/api/creators/${encodeURIComponent(id)}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ outreachStatus: 'outreach_sent' })
      });
      if (res.ok) location.reload();
      else alert('Update failed');
    });
  });
</script>

<style>
  .page-header { margin-bottom: 1.5rem; }
  .page-header h1 {
    font-family: 'Poppins', sans-serif;
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--color-parchment);
  }
  .subtitle {
    font-family: 'Poppins', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--color-slate);
    margin-top: 0.25rem;
  }
  .section { margin-bottom: 2.5rem; }
  .section-title {
    font-family: 'Poppins', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-parchment);
    margin-bottom: 0.75rem;
  }

  /* Authority outbox */
  .outbox-list { display: flex; flex-direction: column; gap: 1rem; }
  .outbox-card {
    background: var(--color-deep-water);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    box-shadow: var(--color-card-shadow);
    padding: 1.25rem;
  }
  .card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }
  .card-title {
    font-family: 'Poppins', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-parchment);
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }
  .thread-link { color: var(--color-parchment); text-decoration: none; }
  .thread-link:hover { color: var(--color-fleece-gold); }
  .argo-tag {
    display: inline-block;
    font-family: 'Poppins', sans-serif;
    font-size: 0.55rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-fleece-gold);
    background: rgba(24,165,148,0.1);
    padding: 0.1rem 0.4rem;
    border-radius: 0.375rem;
    margin-bottom: 0.5rem;
  }
  .card-notes, .card-bio {
    font-family: 'Poppins', sans-serif;
    font-size: 0.7rem;
    color: var(--color-slate);
    margin-bottom: 0.5rem;
    font-style: italic;
  }
  .card-deadline {
    font-family: 'Poppins', sans-serif;
    font-size: 0.6rem;
    font-weight: 500;
    color: var(--color-slate);
  }
  .draft-box {
    background: var(--color-frost);
    border: 1px solid var(--color-border-light);
    border-radius: 0.375rem;
    padding: 0.75rem;
    margin-bottom: 0.75rem;
    max-height: 200px;
    overflow-y: auto;
  }
  .draft-text {
    font-family: 'Poppins', sans-serif;
    font-size: 0.75rem;
    color: var(--color-starlight);
    white-space: pre-wrap;
    word-wrap: break-word;
    line-height: 1.6;
  }
  .card-actions { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .badge {
    font-family: 'Poppins', sans-serif;
    font-size: 0.6rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 0.375rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .badge.subreddit { background: rgba(255,69,0,0.1); color: #e05420; }
  .badge.haro { background: rgba(13,153,255,0.1); color: #0d99ff; }
  .badge.pending { background: rgba(255,159,0,0.12); color: #cc7f00; }
  .badge.posted, .badge.sent { background: rgba(58,201,119,0.12); color: #2a9d5c; }
  .badge.skipped { background: rgba(108,117,125,0.1); color: var(--color-slate); }
  .btn {
    font-family: 'Poppins', sans-serif;
    font-size: 0.65rem;
    font-weight: 500;
    padding: 0.35rem 0.65rem;
    border-radius: 0.375rem;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-starlight);
    cursor: pointer;
    text-decoration: none;
    transition: background 0.15s;
  }
  .btn:hover { background: rgba(0,0,0,0.03); }
  .btn-copy { border-color: rgba(13,153,255,0.4); color: #0d99ff; }
  .btn-open { border-color: rgba(255,69,0,0.4); color: #e05420; }
  .btn-posted, .btn-sent { border-color: rgba(58,201,119,0.4); color: #2a9d5c; }
  .btn-skip { border-color: rgba(108,117,125,0.3); color: var(--color-slate); }

  /* Data table */
  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'Poppins', sans-serif;
    font-size: 0.75rem;
  }
  .data-table th {
    font-family: 'Poppins', sans-serif;
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-slate);
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }
  .data-table td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--color-border-light);
    color: var(--color-starlight);
  }
  .mono { font-family: 'Poppins', sans-serif; font-size: 0.65rem; font-weight: 500; }

  /* Creator pipeline */
  .funnel {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .funnel-stage {
    flex: 1;
    min-width: 100px;
    background: var(--color-deep-water);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    box-shadow: var(--color-card-shadow);
    padding: 0.75rem;
    text-align: center;
  }
  .funnel-count {
    font-family: 'Poppins', sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-fleece-gold);
  }
  .funnel-label {
    font-family: 'Poppins', sans-serif;
    font-size: 0.6rem;
    font-weight: 600;
    color: var(--color-slate);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .funnel-arrow {
    color: var(--color-slate);
    font-size: 1.25rem;
  }
  .discovery-bar {
    font-family: 'Poppins', sans-serif;
    font-size: 0.7rem;
    color: var(--color-slate);
    background: var(--color-frost);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    padding: 0.5rem 0.75rem;
    margin-bottom: 1.5rem;
  }
  .discovery-bar strong { color: var(--color-starlight); }
  .discovery-warn {
    color: var(--color-danger);
    margin-left: 0.5rem;
  }
  .sep { margin: 0 0.35rem; }
  .creator-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 0.75rem;
  }
  .creator-card {
    background: var(--color-deep-water);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    box-shadow: var(--color-card-shadow);
    padding: 1rem;
  }
  .card-top {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(24,165,148,0.1);
    color: var(--color-fleece-gold);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Poppins', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    flex-shrink: 0;
  }
  .card-info { flex: 1; min-width: 0; }
  .creator-name {
    font-family: 'Poppins', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
  }
  .creator-name a { color: var(--color-parchment); text-decoration: none; }
  .creator-name a:hover { color: var(--color-fleece-gold); }
  .creator-handle {
    font-family: 'Poppins', sans-serif;
    font-size: 0.65rem;
    font-weight: 500;
    color: var(--color-slate);
  }
  .score-badge {
    text-align: center;
    padding: 0.25rem 0.5rem;
    border-radius: 0.375rem;
    flex-shrink: 0;
  }
  .score-badge[data-tier="hot"] { background: rgba(255,94,94,0.1); }
  .score-badge[data-tier="warm"] { background: rgba(255,159,0,0.1); }
  .score-badge[data-tier="cold"] { background: rgba(13,153,255,0.1); }
  .score-num {
    font-family: 'Poppins', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-parchment);
  }
  .score-label {
    font-family: 'Poppins', sans-serif;
    font-size: 0.5rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-slate);
  }
  .creator-meta {
    font-family: 'Poppins', sans-serif;
    font-size: 0.7rem;
    color: var(--color-slate);
    margin-bottom: 0.4rem;
  }
  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-bottom: 0.5rem;
  }
  .niche-tag {
    font-family: 'Poppins', sans-serif;
    font-size: 0.55rem;
    font-weight: 600;
    padding: 0.1rem 0.35rem;
    border-radius: 0.375rem;
    background: rgba(13,153,255,0.08);
    color: #0d99ff;
  }
  .creator-notes {
    font-family: 'Poppins', sans-serif;
    font-size: 0.7rem;
    color: var(--color-slate);
    line-height: 1.5;
    margin-bottom: 0.5rem;
  }
  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .status-row { display: flex; align-items: center; gap: 0.5rem; }
  .badge.qualified { background: rgba(24,165,148,0.12); color: var(--color-fleece-gold); }
  .badge.outreach_sent { background: rgba(13,153,255,0.12); color: #0d99ff; }
  .badge.converted { background: rgba(58,201,119,0.12); color: #2a9d5c; }
  .followup-count {
    font-family: 'Poppins', sans-serif;
    font-size: 0.6rem;
    font-weight: 500;
    color: var(--color-slate);
  }
  .btn-profile { border-color: rgba(13,153,255,0.4); color: #0d99ff; }
  .btn-outreach { border-color: rgba(24,165,148,0.4); color: var(--color-fleece-gold); }
  .btn-outreach:hover { background: rgba(24,165,148,0.08); }

  .empty-state {
    text-align: center;
    padding: 3rem;
    color: var(--color-slate);
    background: var(--color-frost);
    border-radius: 0.375rem;
  }
</style>
