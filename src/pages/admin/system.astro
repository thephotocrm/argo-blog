---
export const prerender = false;

import Dashboard from '../../components/admin/Dashboard.astro';
import CronJobStatus from '../../components/admin/CronJobStatus.astro';
import SystemHealth from '../../components/admin/SystemHealth.astro';

import cronData from '../../data/seo/dashboard/cron-status.json';
import siData from '../../data/seo/dashboard/self-improvement.json';
import aiData from '../../data/seo/dashboard/ai-search.json';
import synData from '../../data/seo/dashboard/synthesis.json';
import blData from '../../data/seo/dashboard/backlinks.json';
import convData from '../../data/seo/dashboard/conversions.json';

// Build cron job list from status data
const cronRuns = cronData?.data?.runs || [];
// Derive job list: group by ID, get latest run for each
const jobMap = new Map<string, any>();
for (const run of cronRuns) {
  const existing = jobMap.get(run.id);
  if (!existing || run.timestamp > existing.timestamp) {
    jobMap.set(run.id, run);
  }
}
const jobs = Array.from(jobMap.values()).map(run => ({
  id: run.id,
  name: run.name,
  schedule: '',
  lastRun: run.timestamp,
  status: run.status,
  nextRun: null,
}));
---

<Dashboard title="System" activePage="system">
  <div class="dashboard-header">
    <h1>System</h1>
    <p class="last-updated">SEO engine operations</p>
  </div>

  <CronJobStatus jobs={jobs} />

  <SystemHealth
    selfImprovement={siData?.data}
    aiSearch={aiData?.data}
    synthesis={synData?.data}
    backlinks={blData?.data}
    conversions={convData?.data}
  />
</Dashboard>

<style>
  .dashboard-header {
    margin-bottom: 1.5rem;
  }
  .dashboard-header h1 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    color: var(--color-parchment);
    margin: 0;
  }
  .last-updated {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-slate);
    margin-top: 0.25rem;
  }
</style>
