---
export const prerender = false;

import Dashboard from '../../components/admin/Dashboard.astro';
import { getAuthorityOutbox } from '../../lib/data';

const outbox = getAuthorityOutbox();
const items = outbox.items || [];
const redditPending = items.filter((i: any) => i.type === 'reddit_answer' && i.status === 'pending_review');
const haroPending = items.filter((i: any) => i.type === 'haro_pitch' && i.status === 'pending_review');
const completed = items.filter((i: any) => i.status !== 'pending_review');
---

<Dashboard title="Authority Outreach" activePage="authority">
  <div class="page-header">
    <h1>Authority Outreach</h1>
    <p class="subtitle">{redditPending.length} Reddit answers &middot; {haroPending.length} HARO pitches pending</p>
  </div>

  {redditPending.length > 0 && (
    <section class="section">
      <h2 class="section-title">Reddit Answers</h2>
      <div class="outbox-list">
        {redditPending.map((item: any) => (
          <div class="outbox-card" data-id={item.id}>
            <div class="card-header">
              <span class="badge subreddit">{item.subreddit}</span>
              <span class="badge pending">Pending</span>
            </div>
            <h3 class="card-title">
              <a href={item.thread_url} target="_blank" rel="noopener" class="thread-link">{item.thread_title}</a>
            </h3>
            {item.mentions_argo && <span class="argo-tag">Mentions Argo</span>}
            {item.notes && <p class="card-notes">{item.notes}</p>}
            <div class="draft-box">
              <pre class="draft-text">{item.answer}</pre>
            </div>
            <div class="card-actions">
              <button class="btn btn-copy" data-text={item.answer}>Copy to Clipboard</button>
              <a href={item.thread_url} target="_blank" rel="noopener" class="btn btn-open">Open Thread</a>
              <button class="btn btn-posted" data-id={item.id}>Mark as Posted</button>
              <button class="btn btn-skip" data-id={item.id}>Skip</button>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  {haroPending.length > 0 && (
    <section class="section">
      <h2 class="section-title">HARO Pitches</h2>
      <div class="outbox-list">
        {haroPending.map((item: any) => (
          <div class="outbox-card" data-id={item.id}>
            <div class="card-header">
              <span class="badge haro">HARO</span>
              <span class="badge pending">Pending</span>
              {item.deadline && <span class="card-deadline">Deadline: {item.deadline}</span>}
            </div>
            <h3 class="card-title">{item.query_summary}</h3>
            {item.bio && <p class="card-bio">Bio: {item.bio}</p>}
            {item.notes && <p class="card-notes">{item.notes}</p>}
            <div class="draft-box">
              <pre class="draft-text">{item.pitch}</pre>
            </div>
            <div class="card-actions">
              <button class="btn btn-copy" data-text={item.pitch}>Copy Pitch</button>
              <button class="btn btn-sent" data-id={item.id}>Mark as Sent</button>
              <button class="btn btn-skip" data-id={item.id}>Skip</button>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  {completed.length > 0 && (
    <section class="section">
      <h2 class="section-title">Completed ({completed.length})</h2>
      <table class="data-table">
        <thead>
          <tr><th>Type</th><th>Title / Query</th><th>Status</th><th>Created</th></tr>
        </thead>
        <tbody>
          {completed.map((item: any) => (
            <tr>
              <td class="mono">{item.type}</td>
              <td>{item.thread_title || item.query_summary}</td>
              <td><span class:list={['badge', item.status]}>{item.status}</span></td>
              <td class="mono">{item.created?.split('T')[0]}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  )}

  {items.length === 0 && (
    <div class="empty-state">
      <p>No items in the authority outbox yet.</p>
    </div>
  )}
</Dashboard>

<script>
  // Copy to clipboard
  document.querySelectorAll('.btn-copy').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = (btn as HTMLElement).dataset.text || '';
      try {
        await navigator.clipboard.writeText(text);
        const el = btn as HTMLElement;
        const orig = el.textContent;
        el.textContent = 'Copied!';
        setTimeout(() => { el.textContent = orig; }, 1500);
      } catch {
        // Fallback
        const ta = document.createElement('textarea');
        ta.value = text;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        const el = btn as HTMLElement;
        const orig = el.textContent;
        el.textContent = 'Copied!';
        setTimeout(() => { el.textContent = orig; }, 1500);
      }
    });
  });

  // Status updates
  async function updateOutbox(id: string, status: string) {
    const res = await fetch(`/api/authority-outbox/${encodeURIComponent(id)}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status })
    });
    if (res.ok) location.reload();
    else alert('Update failed');
  }

  document.querySelectorAll('.btn-posted').forEach(btn => {
    btn.addEventListener('click', () => updateOutbox((btn as HTMLElement).dataset.id!, 'posted'));
  });
  document.querySelectorAll('.btn-sent').forEach(btn => {
    btn.addEventListener('click', () => updateOutbox((btn as HTMLElement).dataset.id!, 'sent'));
  });
  document.querySelectorAll('.btn-skip').forEach(btn => {
    btn.addEventListener('click', () => updateOutbox((btn as HTMLElement).dataset.id!, 'skipped'));
  });
</script>

<style>
  .page-header { margin-bottom: 1.5rem; }
  .page-header h1 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    color: var(--color-parchment);
  }
  .subtitle {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-slate);
    margin-top: 0.25rem;
  }
  .section { margin-bottom: 2.5rem; }
  .section-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--color-parchment);
    margin-bottom: 0.75rem;
  }
  .outbox-list { display: flex; flex-direction: column; gap: 1rem; }
  .outbox-card {
    background: var(--color-deep-water);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 4px;
    padding: 1.25rem;
  }
  .card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }
  .card-title {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-parchment);
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }
  .thread-link { color: var(--color-parchment); text-decoration: none; }
  .thread-link:hover { color: var(--color-fleece-gold); }
  .argo-tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-fleece-gold);
    background: rgba(201,162,39,0.1);
    padding: 0.1rem 0.4rem;
    border-radius: 2px;
    margin-bottom: 0.5rem;
  }
  .card-notes, .card-bio {
    font-size: 0.7rem;
    color: var(--color-slate);
    margin-bottom: 0.5rem;
    font-style: italic;
  }
  .card-deadline {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-slate);
  }
  .draft-box {
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 3px;
    padding: 0.75rem;
    margin-bottom: 0.75rem;
    max-height: 200px;
    overflow-y: auto;
  }
  .draft-text {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--color-starlight);
    white-space: pre-wrap;
    word-wrap: break-word;
    line-height: 1.6;
  }
  .card-actions { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .badge {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    padding: 0.15rem 0.5rem;
    border-radius: 2px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .badge.subreddit { background: rgba(255,69,0,0.15); color: #ff6b35; }
  .badge.haro { background: rgba(74,111,165,0.15); color: var(--color-compass-blue); }
  .badge.pending { background: rgba(201,162,39,0.15); color: var(--color-fleece-gold); }
  .badge.posted, .badge.sent { background: rgba(134,239,172,0.1); color: #86efac; }
  .badge.skipped { background: rgba(107,114,128,0.15); color: var(--color-slate); }
  .btn {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    padding: 0.35rem 0.65rem;
    border-radius: 3px;
    border: 1px solid rgba(255,255,255,0.1);
    background: transparent;
    color: var(--color-starlight);
    cursor: pointer;
    text-decoration: none;
    transition: background 0.15s;
  }
  .btn:hover { background: rgba(255,255,255,0.05); }
  .btn-copy { border-color: rgba(74,111,165,0.3); color: var(--color-compass-blue); }
  .btn-open { border-color: rgba(255,107,53,0.3); color: #ff6b35; }
  .btn-posted, .btn-sent { border-color: rgba(134,239,172,0.3); color: #86efac; }
  .btn-skip { border-color: rgba(107,114,128,0.3); color: var(--color-slate); }
  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.75rem;
  }
  .data-table th {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-slate);
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .data-table td {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    color: var(--color-starlight);
  }
  .mono { font-family: var(--font-mono); font-size: 0.65rem; }
  .empty-state {
    text-align: center;
    padding: 3rem;
    color: var(--color-slate);
  }
</style>
