---
export const prerender = false;

import Dashboard from '../../components/admin/Dashboard.astro';
import DistributionPipeline from '../../components/admin/DistributionPipeline.astro';

import distData from '../../data/seo/dashboard/distribution.json';

const data = distData?.data || {};
---

<Dashboard title="Distribution" activePage="distribution">
  <div class="dashboard-header">
    <h1>Distribution</h1>
    <p class="last-updated">{distData?.lastUpdated ? `Updated ${distData.lastUpdated}` : 'Awaiting first data sync'}</p>
  </div>

  <DistributionPipeline
    funnel={data.funnel}
    platforms={data.platforms}
    pendingDrafts={data.pendingDrafts}
    postedContent={data.postedContent}
  />
</Dashboard>

<style>
  .dashboard-header {
    margin-bottom: 1.5rem;
  }
  .dashboard-header h1 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    color: var(--color-parchment);
    margin: 0;
  }
  .last-updated {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-slate);
    margin-top: 0.25rem;
  }
</style>
