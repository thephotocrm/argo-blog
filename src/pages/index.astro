---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const featuredPost = posts[0];
const smallTiles = posts.slice(1, 4);
const gridPosts = posts.slice(4, 13);
const allTags = [...new Set(posts.flatMap(p => p.data.tags || []))];
---

<Base
  title="Argo Studio Blog — Photography Business Resources"
  description="Practical guides, pricing strategies, and workflow tips for photographers who run their own business."
>
  <!-- About Hero Section -->
  <section class="about-hero">
    <div class="container-wide">
      <div class="about-inner">
        <p class="section-label">Welcome to Argo Studio</p>
        <h1 class="about-heading">Helping photographers <span class="highlight">grow their business</span></h1>
        <p class="about-sub">Practical guides, pricing strategies, and workflow tips from photographers who have been where you are.</p>
        <div class="about-author">
          <div class="about-avatar">A</div>
          <div>
            <span class="about-name">Argo Studio</span>
            <span class="about-role">Photography Business Platform</span>
          </div>
        </div>
        <a href="https://argostudio.co" class="about-cta" rel="noopener">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          Get Started
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Tiles -->
  <section class="featured-tiles">
    <div class="container-wide">
      <div class="tiles-grid">
        {featuredPost && (
          <a href={`/blog/${featuredPost.id}`} class="tile tile-large">
            <div class="tile-image" style={featuredPost.data.image ? `background-image: url(${featuredPost.data.image})` : ''}>
              <div class="tile-gradient"></div>
              <div class="tile-content">
                <span class="tile-cat">{featuredPost.data.tags?.[0] || 'Photography'}</span>
                <h2 class="tile-title">{featuredPost.data.title}</h2>
                <p class="tile-excerpt">{featuredPost.data.description}</p>
                <div class="tile-meta">
                  <span class="tile-author">{featuredPost.data.author || 'Argo Studio'}</span>
                  <span class="tile-date">{new Date(featuredPost.data.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
                </div>
              </div>
            </div>
          </a>
        )}
        {smallTiles.map((post) => (
          <a href={`/blog/${post.id}`} class="tile tile-small">
            <div class="tile-image" style={post.data.image ? `background-image: url(${post.data.image})` : ''}>
              <div class="tile-gradient"></div>
              <div class="tile-content">
                <span class="tile-cat">{post.data.tags?.[0] || 'Photography'}</span>
                <h3 class="tile-title">{post.data.title}</h3>
                <div class="tile-meta">
                  <span class="tile-author">{post.data.author || 'Argo Studio'}</span>
                  <span class="tile-date">{new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Tag Pills -->
  {allTags.length > 0 && (
    <section class="tags-section">
      <div class="container-wide">
        <div class="tags-row">
          <span class="tags-label">Read by Topic</span>
          <div class="tags-list">
            {allTags.slice(0, 8).map((tag) => (
              <span class="tag-pill">{tag}</span>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Blog Post Card Grid -->
  {gridPosts.length > 0 && (
    <section class="posts-section">
      <div class="container-wide">
        <div class="section-header">
          <h2>Latest Articles</h2>
        </div>
        <div class="posts-grid">
          {gridPosts.map((post) => (
            <a href={`/blog/${post.id}`} class="post-card">
              <div class="card-image">
                {post.data.image ? (
                  <img src={post.data.image} alt={post.data.title} loading="lazy" />
                ) : (
                  <div class="card-image-placeholder"><span>{post.data.title.charAt(0)}</span></div>
                )}
              </div>
              <div class="card-body">
                <span class="card-cat">{post.data.tags?.[0] || 'Photography'}</span>
                <h3 class="card-title">{post.data.title}</h3>
                <p class="card-desc">{post.data.description}</p>
                <div class="card-footer">
                  <div class="card-author-row">
                    <div class="card-avatar">{(post.data.author || 'A').charAt(0)}</div>
                    <span class="card-author">{post.data.author || 'Argo Studio'}</span>
                  </div>
                  <time datetime={post.data.date}>
                    {new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </time>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Tools -->
  <section class="tools-section">
    <div class="container-wide">
      <div class="tools-header">
        <h2>Free Tools</h2>
        <p class="tools-sub">Plan your photography business with data-driven calculators</p>
      </div>
      <div class="tools-grid">
        <a href="/tools/pricing-calculator" class="tool-card">
          <div class="tool-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="11" y2="10"/><line x1="13" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="11" y2="14"/><line x1="13" y1="14" x2="16" y2="14"/><line x1="8" y1="18" x2="16" y2="18"/></svg>
          </div>
          <p class="overline">Calculator</p>
          <h3>Photography Pricing Calculator</h3>
          <p>Figure out what to charge based on your market, experience, and overhead.</p>
        </a>
        <a href="/tools/roi-calculator" class="tool-card">
          <div class="tool-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 21H4.6c-.56 0-.84 0-1.054-.109a1 1 0 0 1-.437-.437C3 20.24 3 19.96 3 19.4V3"/><path d="m7 14 4-4 4 4 6-6"/></svg>
          </div>
          <p class="overline">Calculator</p>
          <h3>ROI Calculator</h3>
          <p>See how much time and money a photography CRM could save you each month.</p>
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* About Hero */
  .about-hero {
    padding: 4rem 0 3rem;
    text-align: center;
  }
  .about-inner {
    max-width: 640px;
    margin: 0 auto;
  }
  .section-label {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-slate);
    margin-bottom: 1rem;
  }
  .about-heading {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 600;
    letter-spacing: -0.06em;
    line-height: 1.1;
    color: var(--color-night);
    margin: 0 0 1.25rem;
  }
  .highlight {
    background: linear-gradient(93deg, #8cb7ff, #ff8486);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .about-sub {
    font-size: 1.1rem;
    color: var(--color-slate);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  .about-author {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .about-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.9rem;
  }
  .about-name {
    display: block;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-night);
  }
  .about-role {
    display: block;
    font-size: 0.8rem;
    color: var(--color-slate);
  }
  .about-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.5rem;
    background: var(--color-accent);
    color: #fff;
    border-radius: 20px;
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    transition: background 0.2s;
  }
  .about-cta:hover { background: var(--color-accent-hover); text-decoration: none; }

  @media (max-width: 640px) {
    .about-heading { font-size: 2rem; }
  }

  /* Featured Tiles */
  .featured-tiles {
    padding: 2rem 0 0;
  }
  .tiles-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(2, 240px);
    gap: 1rem;
  }
  .tile {
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    color: #fff;
    display: block;
  }
  .tile:hover { text-decoration: none; }
  .tile:hover .tile-image { transform: scale(1.03); }
  .tile-large {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
  }
  .tile-image {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-color: #c4c4c4;
    transition: transform 0.4s ease;
    position: relative;
  }
  .tile-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 30%, rgba(0,0,0,0.7) 100%);
  }
  .tile-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .tile-large .tile-content {
    padding: 2rem;
    gap: 0.6rem;
  }
  .tile-cat {
    display: inline-block;
    width: fit-content;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #fff;
    background: rgba(32, 107, 234, 0.7);
    backdrop-filter: blur(4px);
    padding: 0.25rem 0.65rem;
    border-radius: 4px;
  }
  .tile-title {
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: -0.06em;
    color: #fff;
    margin: 0;
    line-height: 1.2;
  }
  .tile-large .tile-title {
    font-size: 2rem;
  }
  .tile-small .tile-title {
    font-size: 1.15rem;
  }
  .tile-excerpt {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.8);
    line-height: 1.5;
    margin: 0;
    max-width: 500px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .tile-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.7);
  }
  .tile-author { font-weight: 600; color: rgba(255,255,255,0.9); }

  @media (max-width: 1024px) {
    .tiles-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: 300px repeat(3, 200px);
    }
    .tile-large {
      grid-column: 1 / -1;
      grid-row: 1 / 2;
    }
  }
  @media (max-width: 640px) {
    .tiles-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
    }
    .tile-large { grid-column: 1; grid-row: auto; }
    .tile-image { min-height: 240px; }
    .tile-large .tile-title { font-size: 1.5rem; }
  }

  /* Tag Pills */
  .tags-section {
    padding: 2.5rem 0;
  }
  .tags-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .tags-label {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-slate);
    white-space: nowrap;
  }
  .tags-list {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .tag-pill {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 1rem;
    background: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-night);
    transition: all 0.2s;
  }
  .tag-pill:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  /* Posts Grid */
  .posts-section {
    padding: 0 0 4rem;
  }
  .section-header {
    margin-bottom: 1.5rem;
  }
  .section-header h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: -0.06em;
    color: var(--color-night);
    margin: 0;
  }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .post-card {
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    color: var(--color-night);
    box-shadow: 0 8px 32px rgba(22,22,22,0.07);
    transition: box-shadow 0.25s;
  }
  .post-card:hover {
    text-decoration: none;
    box-shadow: 0 12px 40px rgba(22,22,22,0.12);
  }
  .card-image {
    aspect-ratio: 16 / 9;
    background-color: var(--color-placeholder, #e8e8e8);
    overflow: hidden;
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .card-image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #e1e7f0, #d0d8e8);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card-image-placeholder span {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 600;
    color: var(--color-accent);
    opacity: 0.4;
  }
  .card-cat {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-accent);
  }
  .card-body {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .card-title {
    font-family: var(--font-display);
    font-size: 1.625rem;
    font-weight: 600;
    letter-spacing: -0.06em;
    line-height: 1.2;
    color: var(--color-night);
    margin: 0.5rem 0 0;
  }
  .card-desc {
    margin-top: 0.75rem;
    font-size: 1rem;
    color: var(--color-slate);
    line-height: 1.6;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-footer {
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
    color: var(--color-slate);
  }
  .card-author-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .card-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.75rem;
  }
  .card-author {
    font-weight: 600;
    color: var(--color-night);
  }

  @media (max-width: 768px) {
    .posts-grid { grid-template-columns: 1fr; }
  }

  /* Tools */
  .tools-section {
    padding: 3rem 0 4rem;
    border-top: 1px solid var(--color-border);
  }
  .tools-header { margin-bottom: 1.5rem; }
  .tools-header h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 600;
    letter-spacing: -0.06em;
    color: var(--color-night);
    margin: 0;
  }
  .tools-sub {
    margin-top: 0.5rem;
    color: var(--color-slate);
    font-size: 0.95rem;
  }
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .tool-card {
    display: block;
    padding: 2rem;
    background: #ffffff;
    border-radius: 10px;
    color: var(--color-night);
    text-decoration: none;
    box-shadow: 0 8px 32px rgba(22,22,22,0.07);
    transition: box-shadow 0.25s;
  }
  .tool-card:hover {
    text-decoration: none;
    box-shadow: 0 12px 40px rgba(22,22,22,0.12);
  }
  .tool-icon {
    color: var(--color-accent);
    margin-bottom: 1rem;
  }
  .tool-card h3 {
    margin: 0.5rem 0 0;
    font-size: 1.2rem;
    color: var(--color-night);
  }
  .tool-card p:last-child {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-slate);
    line-height: 1.55;
  }

  @media (max-width: 640px) {
    .tools-grid { grid-template-columns: 1fr; }
  }
</style>
