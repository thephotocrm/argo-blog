---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Base
  title="Blog — Argo Studio"
  description="Practical guides, pricing strategies, and workflow tips for photographers who run their own business."
>
  <section class="blog-hero">
    <div class="container">
      <p class="section-label">Resources for Photographers</p>
      <h1>Blog</h1>
      <p class="hero-sub">
        Guides, strategies, and tools from photographers who have been where you are.
      </p>
    </div>
  </section>

  <section class="posts-grid-section">
    <div class="container-wide">
      {posts.length > 0 ? (
        <div class="grid">
          {posts.map((post) => (
            <a href={`/blog/${post.id}`} class="post-card">
              <div class="card-image">
                {post.data.image ? (
                  <img src={post.data.image} alt={post.data.title} loading="lazy" />
                ) : (
                  <div class="card-image-placeholder"><span>{post.data.title.charAt(0)}</span></div>
                )}
              </div>
              <div class="card-body">
                <span class="card-cat">{post.data.tags?.[0] || 'Photography Business'}</span>
                <h3 class="card-title">{post.data.title}</h3>
                <p class="card-desc">{post.data.description}</p>
                <div class="card-footer">
                  <div class="card-author-row">
                    <div class="card-avatar">{(post.data.author || 'A').charAt(0)}</div>
                    <span class="card-author">{post.data.author || 'Argo Studio'}</span>
                  </div>
                  <time datetime={post.data.date}>
                    {new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </time>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <p>Content is on its way. Check back soon.</p>
        </div>
      )}
    </div>
  </section>
</Base>

<style>
  .blog-hero {
    padding: 4rem 0 3rem;
    text-align: center;
  }
  .section-label {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-slate);
    margin-bottom: 0.5rem;
  }
  .blog-hero h1 {
    margin-top: 0.5rem;
  }
  .hero-sub {
    margin-top: 1rem;
    color: var(--color-slate);
    font-size: 1.1rem;
  }
  .posts-grid-section {
    padding: 2rem 0 4rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .post-card {
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    color: var(--color-night);
    box-shadow: 0 8px 32px rgba(22,22,22,0.07);
    transition: box-shadow 0.25s;
  }
  .post-card:hover {
    text-decoration: none;
    box-shadow: 0 12px 40px rgba(22,22,22,0.12);
  }
  .card-image {
    aspect-ratio: 16 / 9;
    background-color: var(--color-placeholder, #e8e8e8);
    overflow: hidden;
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .card-image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #e1e7f0, #d0d8e8);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card-image-placeholder span {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 600;
    color: var(--color-accent);
    opacity: 0.4;
  }
  .card-body {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .card-cat {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-accent);
  }
  .card-title {
    font-family: var(--font-display);
    font-size: 1.625rem;
    font-weight: 600;
    letter-spacing: -0.06em;
    line-height: 1.2;
    color: var(--color-night);
    margin: 0.5rem 0 0;
  }
  .card-desc {
    margin-top: 0.75rem;
    font-size: 1rem;
    color: var(--color-slate);
    line-height: 1.6;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-footer {
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
    color: var(--color-slate);
  }
  .card-author-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .card-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.75rem;
  }
  .card-author {
    font-weight: 600;
    color: var(--color-night);
  }
  .empty-state {
    text-align: center;
    padding: 3rem;
    color: var(--color-slate);
  }

  @media (max-width: 768px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
