---
interface Keyword {
  keyword: string;
  volume: number;
  difficulty: string;
  cluster: string;
  priority: string;
  status: string;
  intent: string;
}

interface Props {
  keywords: Keyword[];
}

const { keywords } = Astro.props;

// Sort: high priority first, then by volume
const sorted = [...keywords].sort((a, b) => {
  const priorityOrder = { high: 0, medium: 1, low: 2 };
  const pDiff = (priorityOrder[a.priority as keyof typeof priorityOrder] || 2) - (priorityOrder[b.priority as keyof typeof priorityOrder] || 2);
  if (pDiff !== 0) return pDiff;
  return b.volume - a.volume;
});
---

<section class="panel">
  <h2>Keyword Queue</h2>
  <p class="subtitle">{keywords.length} keywords tracked across {new Set(keywords.map(k => k.cluster)).size} clusters</p>

  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th>Keyword</th>
          <th>Volume</th>
          <th>Difficulty</th>
          <th>Intent</th>
          <th>Cluster</th>
          <th>Priority</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        {sorted.map(kw => (
          <tr>
            <td><code>{kw.keyword}</code></td>
            <td class="mono">{kw.volume.toLocaleString()}</td>
            <td><span class={`badge diff-${kw.difficulty}`}>{kw.difficulty}</span></td>
            <td class="mono">{kw.intent}</td>
            <td class="mono">{kw.cluster}</td>
            <td><span class={`badge pri-${kw.priority}`}>{kw.priority}</span></td>
            <td><span class={`badge status-${kw.status}`}>{kw.status.replace('_', ' ')}</span></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>

<style>
  .panel {
    background: var(--color-deep-water);
    border: 1px solid var(--color-border);
    border-radius: 0.375rem;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 1px 3px var(--color-card-shadow);
  }
  h2 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-parchment);
    margin: 0 0 0.25rem 0;
  }
  .subtitle {
    font-size: 0.8rem;
    color: var(--color-slate);
    margin-bottom: 1rem;
  }
  .table-scroll {
    overflow-x: auto;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
    min-width: 700px;
  }
  th {
    text-align: left;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-slate);
    padding: 0.5rem 0.6rem;
    border-bottom: 1px solid var(--color-border);
    white-space: nowrap;
  }
  td {
    padding: 0.45rem 0.6rem;
    color: var(--color-starlight);
    border-bottom: 1px solid var(--color-border-light);
  }
  code {
    font-size: 0.8rem;
    color: var(--color-parchment);
  }
  .mono { font-size: 0.8rem; }
  .badge {
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.15rem 0.4rem;
    border-radius: 0.25rem;
    text-transform: capitalize;
    white-space: nowrap;
  }
  .diff-low { background: rgba(58, 201, 119, 0.12); color: #2a9d5c; }
  .diff-medium { background: rgba(255, 159, 0, 0.12); color: #cc7f00; }
  .diff-high { background: rgba(255, 94, 94, 0.12); color: #d94444; }
  .pri-high { background: rgba(24, 165, 148, 0.12); color: var(--color-fleece-gold); }
  .pri-medium { background: rgba(108, 117, 125, 0.12); color: var(--color-slate); }
  .pri-low { background: rgba(108, 117, 125, 0.06); color: var(--color-slate); }
  .status-not_started { background: rgba(108, 117, 125, 0.1); color: var(--color-slate); }
  .status-in_progress { background: rgba(13, 153, 255, 0.12); color: #0d99ff; }
  .status-published { background: rgba(58, 201, 119, 0.12); color: #2a9d5c; }
</style>
