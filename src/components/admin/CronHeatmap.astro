---
interface CronRun {
  id: string;
  name: string;
  status: 'success' | 'fail';
  timestamp: string;
  duration?: number;
}

interface Props {
  runs?: CronRun[];
}

const { runs } = Astro.props;

// Build 7-day grid: for each of the last 7 days, count success/fail
const today = new Date();
const days: Array<{ label: string; date: string; success: number; fail: number; total: number }> = [];

for (let i = 6; i >= 0; i--) {
  const d = new Date(today);
  d.setDate(d.getDate() - i);
  const dateStr = d.toISOString().split('T')[0];
  const label = d.toLocaleDateString('en-US', { weekday: 'short' });
  const dayRuns = (runs || []).filter(r => r.timestamp && r.timestamp.startsWith(dateStr));
  days.push({
    label,
    date: dateStr,
    success: dayRuns.filter(r => r.status === 'success').length,
    fail: dayRuns.filter(r => r.status === 'fail').length,
    total: dayRuns.length,
  });
}

const maxRuns = Math.max(...days.map(d => d.total), 1);
---

<section class="panel">
  <h2>Cron Activity</h2>
  <p class="subtitle">Last 7 days</p>

  {!runs || runs.length === 0 ? (
    <div class="notice">
      <p>No cron activity data yet.</p>
    </div>
  ) : (
    <div class="heatmap-grid">
      {days.map(day => (
        <div class="day-col">
          <div class="day-label">{day.label}</div>
          <div class="day-bar">
            {day.success > 0 && (
              <div class="bar-success" style={`height: ${(day.success / maxRuns) * 100}%`}>
                <span class="bar-count">{day.success}</span>
              </div>
            )}
            {day.fail > 0 && (
              <div class="bar-fail" style={`height: ${(day.fail / maxRuns) * 100}%`}>
                <span class="bar-count">{day.fail}</span>
              </div>
            )}
            {day.total === 0 && (
              <div class="bar-empty"></div>
            )}
          </div>
          <div class="day-total">{day.total}</div>
        </div>
      ))}
    </div>
  )}

  <div class="heatmap-legend">
    <span class="legend-item"><span class="dot success"></span> Success</span>
    <span class="legend-item"><span class="dot fail"></span> Fail</span>
    <span class="legend-item"><span class="dot empty"></span> None</span>
  </div>
</section>

<style>
  .panel {
    background: var(--color-deep-water);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 3px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }
  h2 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-parchment);
    margin: 0 0 0.25rem 0;
  }
  .subtitle {
    font-size: 0.8rem;
    color: var(--color-slate);
    margin-bottom: 1rem;
  }
  .notice {
    background: rgba(107, 114, 128, 0.1);
    border: 1px solid rgba(107, 114, 128, 0.2);
    border-radius: 3px;
    padding: 1rem;
    color: var(--color-slate);
    font-size: 0.85rem;
  }
  .heatmap-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }
  .day-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }
  .day-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-slate);
  }
  .day-bar {
    width: 100%;
    height: 60px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 1px;
  }
  .bar-success {
    background: rgba(34, 197, 94, 0.5);
    border-radius: 2px;
    min-height: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .bar-fail {
    background: rgba(239, 68, 68, 0.5);
    border-radius: 2px;
    min-height: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .bar-empty {
    height: 4px;
    background: rgba(107, 114, 128, 0.2);
    border-radius: 2px;
  }
  .bar-count {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: var(--color-parchment);
  }
  .day-total {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-starlight);
  }
  .heatmap-legend {
    display: flex;
    gap: 1rem;
    font-size: 0.75rem;
    color: var(--color-starlight);
  }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 2px;
    display: inline-block;
  }
  .dot.success { background: rgba(34, 197, 94, 0.5); }
  .dot.fail { background: rgba(239, 68, 68, 0.5); }
  .dot.empty { background: rgba(107, 114, 128, 0.2); }
</style>
