---
interface CronJob {
  id: string;
  name: string;
  schedule: string;
  lastRun: string | null;
  status: 'success' | 'fail' | 'never';
  nextRun: string | null;
}

interface Props {
  jobs?: CronJob[];
}

const { jobs } = Astro.props;
const items = jobs || [];
---

<section class="panel">
  <h2>Cron Job Status</h2>
  <p class="subtitle">All {items.length || 0} scheduled jobs</p>

  {items.length === 0 ? (
    <div class="notice"><p>No cron job status data yet.</p></div>
  ) : (
    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Schedule</th>
            <th>Last Run</th>
            <th>Status</th>
            <th>Next Run</th>
          </tr>
        </thead>
        <tbody>
          {items.map(job => (
            <tr>
              <td>
                <span class="job-name">{job.name}</span>
                <span class="job-id">{job.id}</span>
              </td>
              <td class="mono">{job.schedule}</td>
              <td class="mono">{job.lastRun ? new Date(job.lastRun).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : '—'}</td>
              <td><span class={`badge status-${job.status}`}>{job.status}</span></td>
              <td class="mono">{job.nextRun ? new Date(job.nextRun).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : '—'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</section>

<style>
  .panel {
    background: var(--color-deep-water);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 3px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }
  h2 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-parchment);
    margin: 0 0 0.25rem 0;
  }
  .subtitle {
    font-size: 0.8rem;
    color: var(--color-slate);
    margin-bottom: 1rem;
  }
  .notice {
    background: rgba(107, 114, 128, 0.1);
    border: 1px solid rgba(107, 114, 128, 0.2);
    border-radius: 3px;
    padding: 1rem;
    color: var(--color-slate);
    font-size: 0.85rem;
  }
  .table-scroll { overflow-x: auto; }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
    min-width: 600px;
  }
  th {
    text-align: left;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-slate);
    padding: 0.5rem 0.6rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  td {
    padding: 0.45rem 0.6rem;
    color: var(--color-starlight);
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  }
  .job-name {
    display: block;
    color: var(--color-parchment);
    font-size: 0.8rem;
  }
  .job-id {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-slate);
    margin-top: 0.1rem;
  }
  .mono { font-family: var(--font-mono); font-size: 0.75rem; }
  .badge {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    padding: 0.15rem 0.4rem;
    border-radius: 2px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }
  .status-success { background: rgba(34, 197, 94, 0.15); color: #86efac; }
  .status-fail { background: rgba(220, 38, 38, 0.15); color: #fca5a5; }
  .status-never { background: rgba(107, 114, 128, 0.15); color: var(--color-slate); }
</style>
