---
interface Props {
  status?: 'normal' | 'monitoring' | 'active_update';
  volatilityScore?: number;
  lastChecked?: string | null;
  activeUpdate?: { name: string; detected: string; impact: string } | null;
}

const { status = 'normal', volatilityScore = 0, lastChecked, activeUpdate } = Astro.props;

const statusLabel = status === 'active_update' ? 'Active Update' : status === 'monitoring' ? 'Monitoring' : 'Normal';
const statusClass = status === 'active_update' ? 'alert' : status === 'monitoring' ? 'warn' : 'ok';
---

<section class="panel">
  <h2>Algorithm Status</h2>
  <p class="subtitle">Volatility monitoring · Daily</p>

  <div class="algo-display">
    <div class={`status-indicator ${statusClass}`}>
      <span class="status-dot"></span>
      <span class="status-text">{statusLabel}</span>
    </div>
    <div class="volatility">
      <span class="vol-label">Volatility</span>
      <span class="vol-value">{volatilityScore}%</span>
    </div>
    {lastChecked && (
      <div class="last-check">
        <span class="check-label">Last checked</span>
        <span class="check-value">{new Date(lastChecked).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}</span>
      </div>
    )}
  </div>

  {(status === 'monitoring' || status === 'active_update') && (
    <div class={`algo-banner ${statusClass}`}>
      {status === 'active_update'
        ? 'Algorithm update detected. Content refresh actions paused — hold and observe.'
        : 'Elevated volatility detected. Monitoring for potential algorithm update.'}
    </div>
  )}

  {activeUpdate && (
    <div class="update-details">
      <div class="detail-row">
        <span class="detail-label">Update</span>
        <span class="detail-value">{activeUpdate.name}</span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Detected</span>
        <span class="detail-value">{activeUpdate.detected}</span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Impact</span>
        <span class="detail-value">{activeUpdate.impact}</span>
      </div>
    </div>
  )}
</section>

<style>
  .panel {
    background: var(--color-deep-water);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 3px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }
  h2 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-parchment);
    margin: 0 0 0.25rem 0;
  }
  .subtitle {
    font-size: 0.8rem;
    color: var(--color-slate);
    margin-bottom: 1rem;
  }
  .algo-display {
    display: flex;
    gap: 2rem;
    align-items: center;
    margin-bottom: 1rem;
  }
  .status-indicator {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .status-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .status-indicator.ok .status-dot { background: #86efac; }
  .status-indicator.warn .status-dot { background: var(--color-fleece-gold); }
  .status-indicator.alert .status-dot { background: #ef4444; }
  .status-text {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-parchment);
  }
  .volatility, .last-check {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .vol-label, .check-label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-slate);
  }
  .vol-value, .check-value {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-starlight);
  }
  .algo-banner {
    border-radius: 3px;
    padding: 0.75rem 1rem;
    font-size: 0.8rem;
    margin-bottom: 1rem;
  }
  .algo-banner.warn {
    background: rgba(201, 162, 39, 0.1);
    border: 1px solid rgba(201, 162, 39, 0.2);
    color: var(--color-pale-gold);
  }
  .algo-banner.alert {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.2);
    color: #fca5a5;
  }
  .update-details {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .detail-row {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }
  .detail-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-slate);
    min-width: 70px;
  }
  .detail-value {
    font-size: 0.8rem;
    color: var(--color-starlight);
  }
  @media (max-width: 768px) {
    .algo-display { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
  }
</style>
