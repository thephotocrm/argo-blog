---
interface QueryRow {
  query: string;
  clicks: number;
  impressions: number;
  ctr: number;
  position: number;
}

interface Props {
  queries?: QueryRow[];
  error?: string;
}

const { queries, error } = Astro.props;
---

<section class="panel">
  <h2>Top Queries</h2>
  <p class="subtitle">Google Search Console · Last 28 days</p>

  {error ? (
    <div class="notice">
      <p>{error}</p>
    </div>
  ) : !queries || queries.length === 0 ? (
    <div class="notice">
      <p>No GSC data available yet. Connect your Google Search Console to see query rankings.</p>
    </div>
  ) : (
    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th>Query</th>
            <th>Clicks</th>
            <th>Impressions</th>
            <th>CTR</th>
            <th>Position</th>
          </tr>
        </thead>
        <tbody>
          {queries.map(q => (
            <tr>
              <td><code>{q.query}</code></td>
              <td class="mono">{q.clicks.toLocaleString()}</td>
              <td class="mono">{q.impressions.toLocaleString()}</td>
              <td class="mono">{q.ctr}%</td>
              <td class="mono">
                <span class={q.position <= 10 ? 'pos-good' : q.position <= 20 ? 'pos-ok' : 'pos-low'}>
                  {q.position}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</section>

<style>
  .panel {
    background: var(--color-deep-water);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 3px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }
  h2 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-parchment);
    margin: 0 0 0.25rem 0;
  }
  .subtitle {
    font-size: 0.8rem;
    color: var(--color-slate);
    margin-bottom: 1rem;
  }
  .notice {
    background: rgba(107, 114, 128, 0.1);
    border: 1px solid rgba(107, 114, 128, 0.2);
    border-radius: 3px;
    padding: 1rem;
    color: var(--color-slate);
    font-size: 0.85rem;
  }
  .table-scroll { overflow-x: auto; }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
  }
  th {
    text-align: left;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-slate);
    padding: 0.5rem 0.6rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  td {
    padding: 0.45rem 0.6rem;
    color: var(--color-starlight);
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  }
  code { font-family: var(--font-mono); font-size: 0.75rem; }
  .mono { font-family: var(--font-mono); font-size: 0.75rem; }
  .pos-good { color: #86efac; }
  .pos-ok { color: var(--color-pale-gold); }
  .pos-low { color: var(--color-slate); }
</style>
