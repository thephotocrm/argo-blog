---
interface Props {
  title: string;
  activePage?: string;
}

const { title, activePage = 'overview' } = Astro.props;

const tabs = [
  { id: 'overview', label: 'Command Center', href: '/admin' },
  { id: 'content', label: 'Content', href: '/admin/content' },
  { id: 'outreach', label: 'Outreach', href: '/admin/outreach' },
  { id: 'monitoring', label: 'Monitoring', href: '/admin/monitoring' },
  { id: 'strategy', label: 'Strategy', href: '/admin/strategy' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} — Argo Admin</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --color-night: #f5f5f5;
        --color-deep-water: #ffffff;
        --color-fleece-gold: #18a594;
        --color-pale-gold: #3ac977;
        --color-starlight: #888888;
        --color-parchment: #374557;
        --color-frost: #f8f9fa;
        --color-slate: #6c757d;
        --color-compass-blue: #0d99ff;
        --color-danger: #ff5e5e;
        --color-warning: #ff9f00;
        --color-info: #58bad7;
        --color-success: #3ac977;
        --color-header: #2c2c2c;
        --color-border: #e6e6e6;
        --color-border-light: #f0f0f0;
        --color-card-shadow: rgba(0, 0, 0, 0.04);
        --font-display: 'Poppins', sans-serif;
        --font-body: 'Poppins', sans-serif;
        --font-mono: 'Poppins', sans-serif;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: var(--font-body);
        background: var(--color-night);
        color: var(--color-starlight);
        font-size: 0.875rem;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
      }
    </style>
  </head>
  <body>
    <header class="admin-header">
      <div class="admin-header-inner">
        <div class="admin-brand">
          <a href="/admin" class="admin-logo">Argo Studio</a>
          <span class="admin-badge">Admin</span>
        </div>
        <nav class="admin-nav">
          <a href="/" class="admin-link">Blog</a>
          <a href="/admin/login" class="admin-link logout">Sign Out</a>
        </nav>
      </div>
      <div class="admin-tabs">
        <div class="admin-tabs-inner">
          {tabs.map(tab => (
            <a href={tab.href} class={`tab ${activePage === tab.id ? 'active' : ''}`}>
              {tab.label}
            </a>
          ))}
        </div>
      </div>
    </header>

    <main class="admin-main">
      <slot />
    </main>

    <style>
      .admin-header {
        background: var(--color-header);
      }
      .admin-header-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0.75rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .admin-brand {
        display: flex;
        align-items: center;
        gap: 0.75rem;
      }
      .admin-logo {
        font-family: var(--font-display);
        font-size: 1.15rem;
        font-weight: 600;
        color: #ffffff;
        text-decoration: none;
      }
      .admin-badge {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--color-fleece-gold);
        background: rgba(24, 165, 148, 0.15);
        padding: 0.2rem 0.5rem;
        border-radius: 0.375rem;
      }
      .admin-nav {
        display: flex;
        gap: 1rem;
        align-items: center;
      }
      .admin-link {
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.6);
        text-decoration: none;
      }
      .admin-link:hover { color: #ffffff; }
      .admin-link.logout {
        color: rgba(255, 255, 255, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.15);
        padding: 0.3rem 0.75rem;
        border-radius: 0.375rem;
      }
      .admin-tabs {
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        background: var(--color-header);
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }
      .admin-tabs-inner {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        gap: 0;
      }
      .tab {
        font-family: var(--font-body);
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.5);
        text-decoration: none;
        padding: 0.75rem 1rem;
        border-bottom: 2px solid transparent;
        white-space: nowrap;
        transition: color 0.15s;
      }
      .tab:hover {
        color: rgba(255, 255, 255, 0.8);
      }
      .tab.active {
        color: var(--color-fleece-gold);
        border-bottom-color: var(--color-fleece-gold);
      }
      .admin-main {
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }
    </style>
  </body>
</html>
