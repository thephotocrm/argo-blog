---
interface Props {
  title: string;
  activePage?: string;
}

const { title, activePage = 'overview' } = Astro.props;

const navSections = [
  {
    label: 'DASHBOARD',
    items: [
      { id: 'overview', label: 'Command Center', href: '/admin', icon: 'command' },
    ],
  },
  {
    label: 'MANAGEMENT',
    items: [
      { id: 'content', label: 'Content', href: '/admin/content', icon: 'content' },
      { id: 'outreach', label: 'Outreach', href: '/admin/outreach', icon: 'outreach' },
      { id: 'monitoring', label: 'Monitoring', href: '/admin/monitoring', icon: 'monitoring' },
      { id: 'strategy', label: 'Strategy', href: '/admin/strategy', icon: 'strategy' },
    ],
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} — Argo Admin</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --primary: #18a594;
        --primary-light: rgba(24, 165, 148, 0.1);
        --color-night: #f5f5f5;
        --color-deep-water: #ffffff;
        --color-fleece-gold: #18a594;
        --color-pale-gold: #3ac977;
        --color-starlight: #888888;
        --color-parchment: #374557;
        --color-frost: #f8f9fa;
        --color-slate: #6c757d;
        --color-compass-blue: #0d99ff;
        --color-danger: #ff5e5e;
        --color-warning: #ff9f00;
        --color-info: #58bad7;
        --color-success: #3ac977;
        --color-header: #1e2a4a;
        --color-sidebar: #1e2a4a;
        --color-sidebar-hover: #253254;
        --color-border: #e6e6e6;
        --color-border-light: #f0f0f0;
        --color-card-shadow: rgba(82, 63, 105, 0.05);
        --font-display: 'Poppins', sans-serif;
        --font-body: 'Poppins', sans-serif;
        --font-mono: 'Poppins', sans-serif;
        --sidebar-width: 250px;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: var(--font-body);
        background: var(--color-night);
        color: var(--color-starlight);
        font-size: 0.875rem;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
      }
    </style>
  </head>
  <body>
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-brand">
        <a href="/admin" class="sidebar-logo">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
            <rect width="28" height="28" rx="8" fill="var(--primary)" />
            <text x="7" y="20" font-size="16" font-weight="700" fill="#fff" font-family="Poppins">A</text>
          </svg>
          <span class="sidebar-logo-text">Argo Studio</span>
        </a>
        <span class="sidebar-badge">Admin</span>
      </div>

      <nav class="sidebar-nav">
        {navSections.map((section) => (
          <div class="nav-section">
            <div class="nav-section-label">{section.label}</div>
            <ul class="nav-list">
              {section.items.map((item) => (
                <li>
                  <a href={item.href} class:list={['nav-item', { active: activePage === item.id }]}>
                    <span class="nav-icon">
                      {item.icon === 'command' && (
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                          <rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" />
                        </svg>
                      )}
                      {item.icon === 'content' && (
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14,2 14,8 20,8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /><polyline points="10,9 9,9 8,9" />
                        </svg>
                      )}
                      {item.icon === 'outreach' && (
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87" /><path d="M16 3.13a4 4 0 010 7.75" />
                        </svg>
                      )}
                      {item.icon === 'monitoring' && (
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="22,12 18,12 15,21 9,3 6,12 2,12" />
                        </svg>
                      )}
                      {item.icon === 'strategy' && (
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" />
                        </svg>
                      )}
                    </span>
                    <span class="nav-label">{item.label}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </aside>

    <!-- Header Bar -->
    <header class="top-header">
      <div class="header-left">
        <div class="header-search">
          <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" />
          </svg>
          <input type="text" placeholder="Search..." class="search-input" />
        </div>
      </div>
      <div class="header-right">
        <button class="header-icon-btn" title="Notifications">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9" /><path d="M13.73 21a2 2 0 01-3.46 0" />
          </svg>
        </button>
        <a href="/admin" class="header-icon-btn" title="Settings">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.32 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" />
          </svg>
        </a>
        <div class="header-divider"></div>
        <div class="header-profile">
          <div class="profile-avatar">A</div>
          <div class="profile-info">
            <span class="profile-name">Admin</span>
            <a href="/admin/login" class="profile-signout">Sign Out</a>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content Area -->
    <main class="admin-main">
      <slot />
    </main>

    <style>
      /* Sidebar */
      .sidebar {
        position: fixed;
        left: 0;
        top: 0;
        bottom: 0;
        width: var(--sidebar-width);
        background: var(--color-sidebar);
        z-index: 100;
        display: flex;
        flex-direction: column;
        overflow-y: auto;
      }
      .sidebar-brand {
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
      }
      .sidebar-logo {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        text-decoration: none;
      }
      .sidebar-logo-text {
        font-family: var(--font-display);
        font-size: 1.1rem;
        font-weight: 600;
        color: #ffffff;
      }
      .sidebar-badge {
        font-size: 0.55rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--primary);
        background: rgba(24, 165, 148, 0.15);
        padding: 0.15rem 0.45rem;
        border-radius: 0.25rem;
        margin-left: auto;
      }

      /* Sidebar Navigation */
      .sidebar-nav {
        flex: 1;
        padding: 0.75rem 0;
      }
      .nav-section {
        margin-bottom: 0.5rem;
      }
      .nav-section-label {
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.35);
        padding: 0.75rem 1.5rem 0.4rem;
      }
      .nav-list {
        list-style: none;
      }
      .nav-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.65rem 1.5rem;
        color: rgba(255, 255, 255, 0.6);
        text-decoration: none;
        font-size: 0.8rem;
        font-weight: 400;
        transition: all 0.15s;
        border-left: 3px solid transparent;
      }
      .nav-item:hover {
        color: rgba(255, 255, 255, 0.9);
        background: var(--color-sidebar-hover);
      }
      .nav-item.active {
        color: #ffffff;
        background: var(--color-sidebar-hover);
        border-left-color: var(--primary);
      }
      .nav-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 20px;
        height: 20px;
        flex-shrink: 0;
      }
      .nav-label {
        white-space: nowrap;
      }

      /* Top Header */
      .top-header {
        position: fixed;
        top: 0;
        left: var(--sidebar-width);
        right: 0;
        height: 60px;
        background: var(--color-sidebar);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 1.5rem;
        z-index: 99;
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
      }
      .header-left {
        flex: 1;
        max-width: 400px;
      }
      .header-search {
        position: relative;
        display: flex;
        align-items: center;
      }
      .search-icon {
        position: absolute;
        left: 0.75rem;
        color: rgba(255, 255, 255, 0.4);
        pointer-events: none;
      }
      .search-input {
        width: 100%;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 0.5rem;
        padding: 0.45rem 0.75rem 0.45rem 2.25rem;
        color: #ffffff;
        font-family: var(--font-body);
        font-size: 0.8rem;
        outline: none;
        transition: border-color 0.15s;
      }
      .search-input::placeholder { color: rgba(255, 255, 255, 0.4); }
      .search-input:focus { border-color: var(--primary); }

      .header-right {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .header-icon-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 0.5rem;
        border: none;
        background: transparent;
        color: rgba(255, 255, 255, 0.6);
        cursor: pointer;
        transition: all 0.15s;
        text-decoration: none;
      }
      .header-icon-btn:hover {
        background: rgba(255, 255, 255, 0.08);
        color: #ffffff;
      }
      .header-divider {
        width: 1px;
        height: 24px;
        background: rgba(255, 255, 255, 0.12);
        margin: 0 0.5rem;
      }
      .header-profile {
        display: flex;
        align-items: center;
        gap: 0.6rem;
      }
      .profile-avatar {
        width: 34px;
        height: 34px;
        border-radius: 0.5rem;
        background: var(--primary);
        color: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.8rem;
        font-weight: 600;
      }
      .profile-info {
        display: flex;
        flex-direction: column;
      }
      .profile-name {
        font-size: 0.8rem;
        font-weight: 500;
        color: #ffffff;
        line-height: 1.2;
      }
      .profile-signout {
        font-size: 0.65rem;
        color: rgba(255, 255, 255, 0.5);
        text-decoration: none;
      }
      .profile-signout:hover { color: var(--primary); }

      /* Main Content */
      .admin-main {
        margin-left: var(--sidebar-width);
        margin-top: 60px;
        padding: 1.5rem 2rem 3rem;
        min-height: calc(100vh - 60px);
      }

      /* Responsive */
      @media (max-width: 1024px) {
        .sidebar { width: 220px; }
        .top-header { left: 220px; }
        .admin-main { margin-left: 220px; }
      }
      @media (max-width: 768px) {
        .sidebar { display: none; }
        .top-header { left: 0; }
        .admin-main { margin-left: 0; }
      }
    </style>
  </body>
</html>
