---
interface Props {
  selfImprovement?: {
    predictionAccuracy: number | null;
    learningCount: number;
    confidenceScores: Array<{ label: string; score: number }>;
    capabilityGaps: string[];
    systemHealthScore: number | null;
  };
  aiSearch?: {
    citationRate: number | null;
    scores: Array<{ url: string; score: number }>;
  };
  synthesis?: {
    insights: Array<{ topic: string; summary: string; date: string }>;
  };
  backlinks?: {
    gains: number;
    losses: number;
    survivalRate: number | null;
    total: number;
  };
  conversions?: {
    topKeywords: Array<{ keyword: string; revenue: number; conversions: number }>;
    topPages: Array<{ url: string; revenue: number; conversions: number }>;
  };
}

const { selfImprovement, aiSearch, synthesis, backlinks, conversions } = Astro.props;
const si = selfImprovement || { predictionAccuracy: null, learningCount: 0, confidenceScores: [], capabilityGaps: [], systemHealthScore: null };
const ai = aiSearch || { citationRate: null, scores: [] };
const syn = synthesis || { insights: [] };
const bl = backlinks || { gains: 0, losses: 0, survivalRate: null, total: 0 };
const conv = conversions || { topKeywords: [], topPages: [] };
---

<section class="panel">
  <h2>Self-Improvement</h2>
  <p class="subtitle">Monthly retrospective metrics</p>

  <div class="si-cards">
    <div class="si-card">
      <span class="si-label">Prediction Accuracy</span>
      <span class="si-value">{si.predictionAccuracy != null ? `${si.predictionAccuracy}%` : '—'}</span>
    </div>
    <div class="si-card">
      <span class="si-label">Learnings</span>
      <span class="si-value">{si.learningCount}</span>
    </div>
    <div class="si-card">
      <span class="si-label">System Health</span>
      <span class="si-value">{si.systemHealthScore != null ? si.systemHealthScore : '—'}</span>
    </div>
  </div>

  {si.capabilityGaps.length > 0 && (
    <div class="gaps">
      <h3>Capability Gaps</h3>
      <div class="gap-list">
        {si.capabilityGaps.map(gap => (
          <span class="gap-badge">{gap}</span>
        ))}
      </div>
    </div>
  )}
</section>

<section class="panel">
  <h2>AI Search Visibility</h2>
  <p class="subtitle">Citation rate &amp; LLM-friendliness · Weekly</p>

  <div class="ai-header">
    <div class="ai-rate">
      <span class="ai-rate-label">Citation Rate</span>
      <span class="ai-rate-value">{ai.citationRate != null ? `${ai.citationRate}%` : '—'}</span>
    </div>
  </div>

  {ai.scores.length > 0 && (
    <div class="score-list">
      <h3>LLM-Friendliness Scores</h3>
      {ai.scores.slice(0, 5).map(s => (
        <div class="score-row">
          <span class="score-url" title={s.url}>{s.url}</span>
          <div class="score-bar-track">
            <div class="score-bar-fill" style={`width: ${s.score}%`}></div>
          </div>
          <span class="score-val">{s.score}</span>
        </div>
      ))}
    </div>
  )}
</section>

<section class="panel">
  <h2>Weekly Synthesis</h2>
  <p class="subtitle">Cross-skill insights</p>

  {syn.insights.length === 0 ? (
    <div class="notice"><p>No synthesis insights yet.</p></div>
  ) : (
    <div class="insight-cards">
      {syn.insights.slice(0, 3).map(insight => (
        <div class="insight-card">
          <span class="insight-topic">{insight.topic}</span>
          <p class="insight-summary">{insight.summary}</p>
          <span class="insight-date">{new Date(insight.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
        </div>
      ))}
    </div>
  )}
</section>

<div class="two-col">
  <section class="panel">
    <h2>Backlink Velocity</h2>
    <p class="subtitle">Weekly link monitoring</p>

    <div class="bl-stats">
      <div class="bl-stat">
        <span class="bl-label">Gains</span>
        <span class="bl-value gain">+{bl.gains}</span>
      </div>
      <div class="bl-stat">
        <span class="bl-label">Losses</span>
        <span class="bl-value loss">-{bl.losses}</span>
      </div>
      <div class="bl-stat">
        <span class="bl-label">Survival</span>
        <span class="bl-value">{bl.survivalRate != null ? `${bl.survivalRate}%` : '—'}</span>
      </div>
      <div class="bl-stat">
        <span class="bl-label">Total</span>
        <span class="bl-value">{bl.total}</span>
      </div>
    </div>
  </section>

  <section class="panel">
    <h2>Conversions</h2>
    <p class="subtitle">Revenue attribution · Weekly</p>

    {conv.topKeywords.length === 0 && conv.topPages.length === 0 ? (
      <div class="notice"><p>No conversion data yet.</p></div>
    ) : (
      <div>
        {conv.topKeywords.length > 0 && (
          <div>
            <h3>Top Revenue Keywords</h3>
            {conv.topKeywords.slice(0, 5).map(k => (
              <div class="conv-row">
                <code>{k.keyword}</code>
                <span class="conv-metric">{k.conversions} conv</span>
              </div>
            ))}
          </div>
        )}
      </div>
    )}
  </section>
</div>

<style>
  .panel {
    background: var(--color-deep-water);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 3px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }
  h2 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-parchment);
    margin: 0 0 0.25rem 0;
  }
  h3 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-parchment);
    margin: 1rem 0 0.75rem 0;
  }
  .subtitle {
    font-size: 0.8rem;
    color: var(--color-slate);
    margin-bottom: 1rem;
  }
  .notice {
    background: rgba(107, 114, 128, 0.1);
    border: 1px solid rgba(107, 114, 128, 0.2);
    border-radius: 3px;
    padding: 1rem;
    color: var(--color-slate);
    font-size: 0.85rem;
  }
  .si-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .si-card {
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 3px;
    padding: 1rem;
    text-align: center;
  }
  .si-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-fleece-gold);
    display: block;
    margin-bottom: 0.25rem;
  }
  .si-value {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-parchment);
    display: block;
    line-height: 1.2;
  }
  .gaps { margin-top: 0.5rem; }
  .gap-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .gap-badge {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    padding: 0.2rem 0.5rem;
    border-radius: 2px;
    background: rgba(220, 38, 38, 0.1);
    color: #fca5a5;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .ai-header { margin-bottom: 1rem; }
  .ai-rate-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-fleece-gold);
    display: block;
    margin-bottom: 0.25rem;
  }
  .ai-rate-value {
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-parchment);
  }
  .score-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .score-row {
    display: grid;
    grid-template-columns: 160px 1fr 40px;
    gap: 0.5rem;
    align-items: center;
  }
  .score-url {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-starlight);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .score-bar-track {
    height: 12px;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 2px;
    overflow: hidden;
  }
  .score-bar-fill {
    height: 100%;
    background: var(--color-compass-blue);
    border-radius: 2px;
    opacity: 0.7;
  }
  .score-val {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-slate);
    text-align: right;
  }
  .insight-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
  }
  .insight-card {
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 3px;
    padding: 1rem;
  }
  .insight-topic {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-fleece-gold);
    display: block;
    margin-bottom: 0.5rem;
  }
  .insight-summary {
    font-size: 0.8rem;
    color: var(--color-starlight);
    line-height: 1.5;
    margin: 0 0 0.5rem 0;
  }
  .insight-date {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-slate);
  }
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .two-col .panel { margin-bottom: 0; }
  .bl-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }
  .bl-stat { text-align: center; }
  .bl-label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-slate);
    display: block;
    margin-bottom: 0.15rem;
  }
  .bl-value {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-parchment);
    display: block;
  }
  .bl-value.gain { color: #86efac; }
  .bl-value.loss { color: #fca5a5; }
  code {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    background: rgba(255, 255, 255, 0.04);
    padding: 0.15rem 0.4rem;
    border-radius: 2px;
  }
  .conv-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.35rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  }
  .conv-metric {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-slate);
  }
  @media (max-width: 900px) {
    .two-col { grid-template-columns: 1fr; }
    .si-cards { grid-template-columns: 1fr; }
    .bl-stats { grid-template-columns: repeat(2, 1fr); }
  }
</style>
