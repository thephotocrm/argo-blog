---
interface ActivityItem {
  competitor: string;
  action: string;
  details: string;
  date: string;
}

interface ContentGap {
  keyword: string;
  volume: number;
  difficulty: string;
  competitor: string;
}

interface Threat {
  domain: string;
  overlappingKeywords: number;
  newContent: number;
}

interface Props {
  activity?: ActivityItem[];
  contentGaps?: ContentGap[];
  threats?: Threat[];
}

const { activity, contentGaps, threats } = Astro.props;
const acts = activity || [];
const gaps = contentGaps || [];
const thrs = threats || [];
---

<section class="panel">
  <h2>Competitor Activity</h2>
  <p class="subtitle">Recent competitor moves</p>

  {acts.length === 0 ? (
    <div class="notice"><p>No competitor activity tracked yet.</p></div>
  ) : (
    <div class="activity-feed">
      {acts.slice(0, 10).map(item => (
        <div class="activity-item">
          <span class="activity-date">{new Date(item.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
          <div class="activity-content">
            <span class="activity-competitor">{item.competitor}</span>
            <span class="activity-action">{item.action}</span>
            <span class="activity-details">{item.details}</span>
          </div>
        </div>
      ))}
    </div>
  )}
</section>

<section class="panel">
  <h2>Content Gaps</h2>
  <p class="subtitle">Top keyword opportunities · Monthly</p>

  {gaps.length === 0 ? (
    <div class="notice"><p>No content gap data yet.</p></div>
  ) : (
    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th>Keyword</th>
            <th>Volume</th>
            <th>Difficulty</th>
            <th>Competitor</th>
          </tr>
        </thead>
        <tbody>
          {gaps.slice(0, 10).map(g => (
            <tr>
              <td><code>{g.keyword}</code></td>
              <td class="mono">{g.volume.toLocaleString()}</td>
              <td><span class={`badge diff-${g.difficulty}`}>{g.difficulty}</span></td>
              <td class="mono">{g.competitor}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</section>

<section class="panel">
  <h2>Threat Matrix</h2>
  <p class="subtitle">Competitor overlap assessment</p>

  {thrs.length === 0 ? (
    <div class="notice"><p>No threat data yet.</p></div>
  ) : (
    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th>Domain</th>
            <th>Overlapping KWs</th>
            <th>New Content</th>
          </tr>
        </thead>
        <tbody>
          {thrs.map(t => (
            <tr>
              <td><code>{t.domain}</code></td>
              <td class="mono">{t.overlappingKeywords}</td>
              <td class="mono">{t.newContent}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</section>

<style>
  .panel {
    background: var(--color-deep-water);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 3px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }
  h2 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--color-parchment);
    margin: 0 0 0.25rem 0;
  }
  .subtitle {
    font-size: 0.8rem;
    color: var(--color-slate);
    margin-bottom: 1rem;
  }
  .notice {
    background: rgba(107, 114, 128, 0.1);
    border: 1px solid rgba(107, 114, 128, 0.2);
    border-radius: 3px;
    padding: 1rem;
    color: var(--color-slate);
    font-size: 0.85rem;
  }
  .activity-feed {
    display: flex;
    flex-direction: column;
  }
  .activity-item {
    display: flex;
    gap: 0.75rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  }
  .activity-date {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-slate);
    min-width: 50px;
    flex-shrink: 0;
    padding-top: 0.1rem;
  }
  .activity-content {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    align-items: baseline;
    font-size: 0.8rem;
  }
  .activity-competitor {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    background: rgba(201, 162, 39, 0.1);
    color: var(--color-fleece-gold);
    padding: 0.1rem 0.35rem;
    border-radius: 2px;
  }
  .activity-action {
    color: var(--color-starlight);
    font-weight: 500;
  }
  .activity-details {
    color: var(--color-slate);
    font-size: 0.75rem;
  }
  .table-scroll { overflow-x: auto; }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
  }
  th {
    text-align: left;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-slate);
    padding: 0.5rem 0.6rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  td {
    padding: 0.45rem 0.6rem;
    color: var(--color-starlight);
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  }
  code {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    background: rgba(255, 255, 255, 0.04);
    padding: 0.15rem 0.4rem;
    border-radius: 2px;
  }
  .mono { font-family: var(--font-mono); font-size: 0.75rem; }
  .badge {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    padding: 0.15rem 0.4rem;
    border-radius: 2px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }
  .diff-low { background: rgba(34, 197, 94, 0.15); color: #86efac; }
  .diff-medium { background: rgba(201, 162, 39, 0.15); color: var(--color-pale-gold); }
  .diff-high { background: rgba(220, 38, 38, 0.15); color: #fca5a5; }
</style>
