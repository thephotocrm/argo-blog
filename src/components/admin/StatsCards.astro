---
interface Props {
  gscTotals?: { clicks: number; impressions: number; avgPosition: number };
  ga4Totals?: { sessions: number; pageviews: number };
  publishedPosts: number;
  totalKeywords: number;
  systemHealth?: number | null;
  cronStatus?: { succeeded: number; total: number } | null;
  algoStatus?: string | null;
  distributionQueue?: number | null;
}

const { gscTotals, ga4Totals, publishedPosts, totalKeywords, systemHealth, cronStatus, algoStatus, distributionQueue } = Astro.props;
---

<div class="stats-grid">
  <div class="stat-card">
    <span class="stat-label">Total Clicks</span>
    <span class="stat-value">{gscTotals ? gscTotals.clicks.toLocaleString() : '—'}</span>
    <span class="stat-source">GSC · 28d</span>
  </div>
  <div class="stat-card">
    <span class="stat-label">Impressions</span>
    <span class="stat-value">{gscTotals ? gscTotals.impressions.toLocaleString() : '—'}</span>
    <span class="stat-source">GSC · 28d</span>
  </div>
  <div class="stat-card">
    <span class="stat-label">Avg Position</span>
    <span class="stat-value">{gscTotals ? gscTotals.avgPosition : '—'}</span>
    <span class="stat-source">GSC · 28d</span>
  </div>
  <div class="stat-card">
    <span class="stat-label">Sessions</span>
    <span class="stat-value">{ga4Totals ? ga4Totals.sessions.toLocaleString() : '—'}</span>
    <span class="stat-source">GA4 · 28d</span>
  </div>
  <div class="stat-card">
    <span class="stat-label">Published Posts</span>
    <span class="stat-value">{publishedPosts}</span>
    <span class="stat-source">Blog</span>
  </div>
  <div class="stat-card">
    <span class="stat-label">Keywords Tracked</span>
    <span class="stat-value">{totalKeywords}</span>
    <span class="stat-source">SEO Engine</span>
  </div>
  <div class="stat-card">
    <span class="stat-label">System Health</span>
    <span class="stat-value">{systemHealth != null ? systemHealth : '—'}</span>
    <span class="stat-source">SEO Engine</span>
  </div>
  <div class="stat-card">
    <span class="stat-label">Crons 24h</span>
    <span class="stat-value">{cronStatus ? `${cronStatus.succeeded}/${cronStatus.total}` : '—'}</span>
    <span class="stat-source">SEO Engine</span>
  </div>
  <div class="stat-card">
    <span class="stat-label">Algo Status</span>
    <span class={`stat-value ${algoStatus === 'Update Detected' ? 'stat-warn' : ''}`}>{algoStatus || '—'}</span>
    <span class="stat-source">SEO Engine</span>
  </div>
  <div class="stat-card">
    <span class="stat-label">Dist. Queue</span>
    <span class="stat-value">{distributionQueue != null ? distributionQueue : '—'}</span>
    <span class="stat-source">Distribution</span>
  </div>
</div>

<style>
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .stat-card {
    background: var(--color-deep-water);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 3px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-fleece-gold);
  }
  .stat-value {
    font-family: var(--font-mono);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-parchment);
    line-height: 1.2;
  }
  .stat-source {
    font-size: 0.7rem;
    color: var(--color-slate);
  }
  .stat-warn {
    color: #fca5a5;
    font-size: 1rem;
  }
</style>
