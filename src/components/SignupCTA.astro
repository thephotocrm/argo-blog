---
interface Props {
  heading?: string;
  text?: string;
  buttonText?: string;
  buttonUrl?: string;
}

const {
  heading = 'Ready to simplify your photography business?',
  text = 'Argo Studio handles contracts, invoices, scheduling, and client communication — so you can focus on the work that matters.',
  buttonText = 'Try Argo Studio',
  buttonUrl = 'https://argostudio.co/signup',
} = Astro.props;
---

<section class="signup-cta">
  <div class="cta-inner">
    <h2>{heading}</h2>
    <p>{text}</p>
    <a href={buttonUrl} class="cta-button" rel="noopener">{buttonText}</a>
  </div>
</section>

<style>
  .signup-cta {
    margin-top: 3rem;
    padding: 3rem;
    background: linear-gradient(135deg, var(--color-deep-water) 0%, #1e2340 100%);
    border-radius: 8px;
    position: relative;
    overflow: hidden;
  }
  .signup-cta::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: rgba(201, 162, 39, 0.08);
    pointer-events: none;
  }
  .cta-inner {
    text-align: center;
    position: relative;
  }
  .signup-cta h2 {
    color: var(--color-parchment);
    font-size: 1.75rem;
    margin-top: 0;
  }
  .signup-cta p {
    color: var(--color-starlight);
    margin-top: 0.75rem;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }
  .cta-button {
    display: inline-block;
    margin-top: 1.75rem;
    padding: 0.85rem 2.25rem;
    background: var(--color-fleece-gold);
    color: var(--color-night);
    border-radius: 4px;
    font-weight: 700;
    font-size: 0.95rem;
    transition: opacity 0.15s;
  }
  .cta-button:hover {
    text-decoration: none;
    opacity: 0.9;
  }
</style>
