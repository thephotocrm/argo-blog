---
interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  url: string;
  publishedDate?: string;
  keywords?: string[];
  jsonLd?: object;
  breadcrumbs?: Array<{ name: string; url: string }>;
  pageType?: 'comparison' | 'alternative' | 'niche' | 'city' | 'integration' | 'blog' | 'tool' | 'default';
}

const {
  title,
  description,
  image = '/og-images/default.png',
  type = 'website',
  url,
  publishedDate,
  keywords = [],
  jsonLd,
  breadcrumbs,
  pageType = 'default',
} = Astro.props;

const fullTitle = title.includes('Argo') ? title : `${title} | Argo Studio`;
const fullImageUrl = image.startsWith('http') ? image : new URL(image, Astro.site).href;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Argo Studio',
  url: 'https://argostudio.co',
  logo: 'https://argostudio.co/logo.png',
  description: 'Photography business management built by photographers, for photographers.',
  sameAs: [],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Argo Studio Blog',
  url: 'https://blog.argostudio.co',
  publisher: {
    '@type': 'Organization',
    name: 'Argo Studio',
  },
};

const softwareSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Argo Studio',
  applicationCategory: 'BusinessApplication',
  applicationSubCategory: 'Photography CRM',
  operatingSystem: 'Web',
  url: 'https://argostudio.co',
  description: 'Photography CRM built exclusively for photographers. Manage clients, contracts, invoices, scheduling, and gallery delivery in one platform.',
  offers: {
    '@type': 'Offer',
    price: '17',
    priceCurrency: 'USD',
    priceValidUntil: '2026-12-31',
    availability: 'https://schema.org/InStock',
    url: 'https://argostudio.co/pricing',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    ratingCount: '47',
    bestRating: '5',
    worstRating: '1',
  },
  featureList: [
    'Client Portal',
    'Contract Automation',
    'Invoice Management',
    'Session Scheduling',
    'Gallery Delivery Integration',
    'Shot List Management',
    'Payment Reminders',
    'Workflow Automation',
  ],
};

const articleSchema = type === 'article' ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  image: fullImageUrl,
  datePublished: publishedDate,
  author: {
    '@type': 'Organization',
    name: 'Argo Studio',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Argo Studio',
    logo: {
      '@type': 'ImageObject',
      url: 'https://argostudio.co/logo.png',
    },
  },
} : null;

const breadcrumbSchema = breadcrumbs && breadcrumbs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((crumb, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: crumb.name,
    item: crumb.url,
  })),
} : null;

const schemas = [organizationSchema, websiteSchema, softwareSchema];
if (articleSchema) schemas.push(articleSchema);
if (breadcrumbSchema) schemas.push(breadcrumbSchema);
if (jsonLd) schemas.push(jsonLd);
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={url} />
{keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}

<!-- Open Graph -->
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImageUrl} />
<meta property="og:url" content={url} />
<meta property="og:type" content={type} />
<meta property="og:site_name" content="Argo Studio" />
{publishedDate && <meta property="article:published_time" content={publishedDate} />}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImageUrl} />

<!-- JSON-LD Structured Data -->
{schemas.map((schema) => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
